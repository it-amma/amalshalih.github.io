---
import BaseHead from '../components/BaseHead.astro';
import Container from '../components/ui/Container.astro';
import Icon from '../components/ui/Icon.astro';
import { CONTACT, SITE, SOCIAL } from '../data/site';
import { NAV_ITEMS } from '../lib/constants';

interface Props {
	title: string;
	description: string;
	image?: string;
	currentPage?: string;
	pageType?: 'website' | 'article';
}

const { title, description, image, currentPage, pageType } = Astro.props;
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title={title} description={description} image={image} pageType={pageType} />
	</head>
	<body class="flex min-h-screen flex-col">
		<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-primary-600 focus:px-4 focus:py-3 focus:text-sm focus:font-semibold focus:text-white focus:shadow-lg">
			Langsung ke konten utama
		</a>
		<header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-primary-100">
			<nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-2.5 sm:py-3">
				<a href="/" class="flex items-center gap-2 sm:gap-3">
					<img src="/logo-yayasan-sm.webp" alt="Logo Yayasan ASIB" class="h-10 w-10 sm:h-12 sm:w-12 rounded-full object-cover" width="48" height="48" fetchpriority="high" decoding="async" />
					<div class="hidden sm:block">
						<p class="text-sm font-bold leading-tight text-primary-800">Yayasan Amal Shalih</p>
						<p class="text-xs text-warm-700">Insan Bantul</p>
					</div>
					<div class="sm:hidden">
						<p class="text-sm font-bold text-primary-800">Yayasan ASIB</p>
					</div>
				</a>

				<!-- Desktop Nav -->
				<div class="hidden sm:flex items-center gap-1">
					{NAV_ITEMS.map((item) => (
						<a
						href={item.href}
						aria-current={currentPage === item.href ? 'page' : undefined}
						class={`rounded-lg px-3 py-2 text-sm font-medium transition-colors ${
							currentPage === item.href
								? 'bg-primary-50 text-primary-700'
								: 'text-warm-700 hover:bg-warm-100 hover:text-warm-800'
						}`}
					>
						{item.label}
						</a>
					))}
					<a
						href="/donasi"
						class="ml-2 rounded-lg bg-primary-700 px-4 py-2 text-sm font-semibold text-white hover:bg-primary-800 transition-colors"
					>
						Donasi
					</a>
				</div>

				<!-- Mobile Menu Button -->
				<button
					id="mobile-menu-button"
					type="button"
					class="sm:hidden p-1.5 rounded-lg text-primary-800 hover:bg-primary-50 transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2"
					aria-expanded="false"
					aria-controls="mobile-menu"
					aria-label="Buka menu navigasi"
				>
					<Icon name="menu" size={5} class="menu-icon" aria-hidden="true" />
					<Icon name="close" size={5} class="close-icon hidden" aria-hidden="true" />
				</button>
			</nav>

			<!-- Mobile Nav Drawer -->
			<div
				id="mobile-menu"
				class="sm:hidden absolute top-full left-0 w-full bg-white border-b border-primary-100 shadow-lg transition-max-height duration-300 ease-in-out, opacity duration-300 ease-in-out max-h-0 overflow-hidden opacity-0"
				aria-hidden="true"
			>
				<div class="flex flex-col p-4 space-y-1">
					{NAV_ITEMS.map((item) => (
						<a
						href={item.href}
						aria-current={currentPage === item.href ? 'page' : undefined}
						class={`rounded-lg px-4 py-3 text-base font-medium transition-colors ${
							currentPage === item.href
								? 'bg-primary-50 text-primary-700'
								: 'text-warm-700 hover:bg-warm-100 hover:text-warm-800'
						}`}
					>
						{item.label}
						</a>
					))}
					<div class="pt-3 border-t border-primary-100">
						<a
							href="/donasi"
							class="block w-full text-center rounded-lg bg-primary-700 px-4 py-3 text-base font-semibold text-white hover:bg-primary-800 transition-colors"
						>
							Donasi Sekarang
						</a>
					</div>
				</div>
			</div>
		</header>

		<script>
			const menuButton = document.getElementById('mobile-menu-button');
			const mobileMenu = document.getElementById('mobile-menu');
			const menuIcon = menuButton?.querySelector('.menu-icon');
			const closeIcon = menuButton?.querySelector('.close-icon');

			function getFocusableElements() {
				if (!mobileMenu) return [];
				return Array.from(
					mobileMenu.querySelectorAll('a[href], button:not([disabled])')
				).filter((el) => el instanceof HTMLElement && el.offsetParent !== null) as HTMLElement[];
			}

			function toggleMenu() {
				if (!menuButton || !mobileMenu || !menuIcon || !closeIcon) return;

				const isExpanded = menuButton.getAttribute('aria-expanded') === 'true';
				menuButton.setAttribute('aria-expanded', String(!isExpanded));
				mobileMenu.setAttribute('aria-hidden', String(isExpanded));

				if (!isExpanded) {
					mobileMenu.classList.remove('max-h-0', 'opacity-0');
					mobileMenu.classList.add('max-h-96', 'opacity-100');
					menuIcon.classList.add('hidden');
					closeIcon.classList.remove('hidden');
					// Focus first link for keyboard users
					const firstLink = mobileMenu.querySelector('a');
					if (firstLink instanceof HTMLElement) {
						firstLink.focus();
					}
				} else {
					mobileMenu.classList.remove('max-h-96', 'opacity-100');
					mobileMenu.classList.add('max-h-0', 'opacity-0');
					menuIcon.classList.remove('hidden');
					closeIcon.classList.add('hidden');
					// Return focus to menu button
					menuButton.focus();
				}
			}

			menuButton?.addEventListener('click', toggleMenu);

			// Close on Escape key + focus trap
			document.addEventListener('keydown', (e) => {
				if (!menuButton || menuButton.getAttribute('aria-expanded') !== 'true') return;

				if (e.key === 'Escape') {
					e.preventDefault();
					toggleMenu();
					return;
				}

				// Focus trap inside mobile menu
				if (e.key === 'Tab') {
					const focusables = getFocusableElements();
					if (focusables.length === 0) return;
					const first = focusables[0];
					const last = focusables[focusables.length - 1];
					const active = document.activeElement;

					if (e.shiftKey) {
						if (active === first || !mobileMenu?.contains(active as Node)) {
							e.preventDefault();
							last.focus();
						}
					} else {
						if (active === last || !mobileMenu?.contains(active as Node)) {
							e.preventDefault();
							first.focus();
						}
					}
				}
			});

			// Close when clicking outside
			document.addEventListener('click', (e) => {
				if (
					menuButton?.getAttribute('aria-expanded') === 'true' &&
					!mobileMenu?.contains(e.target as Node) &&
					!menuButton?.contains(e.target as Node)
				) {
					toggleMenu();
				}
			});
		</script>

		<main id="main-content" class="flex-1" tabindex="-1">
			<slot />
		</main>

		<footer class="bg-primary-950 text-white">
			<Container as="div" class="py-8 sm:py-12">
				<div class="grid gap-6 sm:gap-8 grid-cols-2 lg:grid-cols-4">
					<!-- About — spans 2 cols on mobile -->
					<div class="col-span-2 sm:col-span-1 min-w-0">
						<h3 class="mb-3 text-lg font-bold text-white">{SITE.shortName}</h3>
						<p class="text-sm text-primary-200 leading-relaxed break-words">
							{SITE.description}
						</p>
					</div>
					<div class="min-w-0">
						<h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary-300">Navigasi</h3>
						<ul class="space-y-2 text-sm">
						<li><a href="/" aria-current={currentPage === '/' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Beranda</a></li>
						<li><a href="/tentang" aria-current={currentPage === '/tentang' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Tentang Kami</a></li>
						<li><a href="/program" aria-current={currentPage === '/program' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Program</a></li>
						<li><a href="/kegiatan" aria-current={currentPage === '/kegiatan' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Kegiatan</a></li>
						<li><a href="/donasi" aria-current={currentPage === '/donasi' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Donasi</a></li>
						<li><a href="/kontak" aria-current={currentPage === '/kontak' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Kontak</a></li>
						</ul>
					</div>
				<div class="min-w-0">
					<h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary-300">Kontak</h3>
					<ul class="space-y-2 text-sm text-primary-200 break-words">
						<li class="break-words">{CONTACT.address.full}</li>
						<li><a href={CONTACT.phoneUrl} class="hover:text-white transition-colors">{CONTACT.phone}</a></li>
						<li><a href={`mailto:${CONTACT.email}`} class="break-all hover:text-white transition-colors">{CONTACT.email}</a></li>
					</ul>
				</div>
					<!-- Social — spans 2 cols on mobile -->
					<div class="col-span-2 sm:col-span-1 min-w-0">
						<h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary-300">Ikuti Kami</h3>
						<div class="flex flex-wrap gap-3 text-primary-300">
							<a href={SOCIAL.facebook.url} target="_blank" rel="noopener noreferrer" class="p-2.5 rounded-lg hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-950" aria-label={SOCIAL.facebook.ariaLabel}>
								<Icon name="facebook" size={5} aria-hidden="true" />
							</a>
							<a href={SOCIAL.instagram.url} target="_blank" rel="noopener noreferrer" class="p-2.5 rounded-lg hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-950" aria-label={SOCIAL.instagram.ariaLabel}>
								<Icon name="instagram" size={5} aria-hidden="true" />
							</a>
							<a href={SOCIAL.tiktok.url} target="_blank" rel="noopener noreferrer" class="p-2.5 rounded-lg hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-950" aria-label={SOCIAL.tiktok.ariaLabel}>
								<Icon name="tiktok" size={5} aria-hidden="true" />
							</a>
							<a href={SOCIAL.youtube.url} target="_blank" rel="noopener noreferrer" class="p-2.5 rounded-lg hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-950" aria-label={SOCIAL.youtube.ariaLabel}>
								<Icon name="youtube" size={5} aria-hidden="true" />
							</a>
							<a href={CONTACT.whatsapp} target="_blank" rel="noopener noreferrer" class="p-2.5 rounded-lg hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-950" aria-label="WhatsApp">
								<Icon name="whatsapp" size={5} aria-hidden="true" />
							</a>
							<a href={SOCIAL.linktree.url} target="_blank" rel="noopener noreferrer" class="p-2.5 rounded-lg hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-950" aria-label="Linktree">
								<Icon name="external-link" size={5} aria-hidden="true" />
							</a>
						</div>
					</div>
				</div>
				<div class="mt-8 border-t border-primary-800 pt-5 text-center text-sm text-primary-400">
					&copy; {new Date().getFullYear()} {SITE.name}. Seluruh hak cipta dilindungi.
				</div>
			</Container>
		</footer>
	</body>
</html>
