---
import BaseHead from '../components/BaseHead.astro';
import Container from '../components/ui/Container.astro';
import Icon from '../components/ui/Icon.astro';
import { CONTACT, SITE, SOCIAL } from '../data/site';
import { NAV_ITEMS } from '../lib/constants';

interface Props {
	title: string;
	description: string;
	image?: string;
	currentPage?: string;
	pageType?: 'website' | 'article';
	publishedTime?: string;
	modifiedTime?: string;
}

const { title, description, image, currentPage, pageType, publishedTime, modifiedTime } = Astro.props;
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead 
		title={title} 
		description={description} 
		image={image} 
		pageType={pageType} 
		publishedTime={publishedTime} 
		modifiedTime={modifiedTime} 
	/>
	</head>
	<body class="flex min-h-screen flex-col">
		<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-primary-600 focus:px-4 focus:py-3 focus:text-sm focus:font-semibold focus:text-white focus:shadow-lg">
			Langsung ke konten utama
		</a>
		<header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-primary-100">
			<nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-2.5 sm:py-3">
				<a href="/" class="flex items-center gap-2 sm:gap-3 shrink-0">
					<img src="/logo-yayasan-sm.webp" alt="Logo Yayasan ASIB" class="h-10 w-10 sm:h-12 sm:w-12 rounded-full object-cover" width="48" height="48" fetchpriority="high" decoding="async" />
					<div class="hidden sm:block whitespace-nowrap">
						<p class="text-sm font-bold leading-tight text-primary-800">Yayasan Amal Shalih</p>
						<p class="text-xs text-warm-700">Insan Bantul</p>
					</div>
					<div class="sm:hidden">
						<p class="text-sm font-bold text-primary-800">Yayasan ASIB</p>
					</div>
				</a>

				<!-- Desktop Nav -->
				<div class="hidden sm:flex items-center justify-end gap-1 overflow-hidden">
					<div class="flex items-center gap-1 overflow-x-auto scrollbar-hide whitespace-nowrap snap-x snap-mandatory min-w-0 max-w-[280px] md:max-w-none">
						{NAV_ITEMS.map((item) => (
							<a
							href={item.href}
							aria-current={currentPage === item.href ? 'page' : undefined}
							class={`rounded-lg px-3 py-2 text-sm font-medium transition-colors shrink-0 snap-start ${
								currentPage === item.href
									? 'bg-primary-50 text-primary-700'
									: 'text-warm-700 hover:bg-warm-100 hover:text-warm-800'
							}`}
						>
							{item.label}
							</a>
						))}
					</div>
					<a
						href="/donasi"
						class="ml-2 rounded-lg bg-primary-700 px-4 py-2 text-sm font-semibold text-white hover:bg-primary-800 transition-colors shrink-0"
					>
						Donasi
					</a>
				</div>

				<!-- Mobile Menu Button -->
				<button
					id="mobile-menu-button"
					type="button"
					class="sm:hidden p-1.5 rounded-lg text-primary-800 hover:bg-primary-50 transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2"
					aria-expanded="false"
					aria-controls="mobile-menu"
					aria-label="Buka menu navigasi"
				>
					<Icon name="menu" size={5} class="menu-icon" aria-hidden="true" />
					<Icon name="close" size={5} class="close-icon hidden" aria-hidden="true" />
				</button>
			</nav>

			<!-- Mobile Nav Drawer -->
			<div
				id="mobile-menu"
				class="sm:hidden absolute top-full left-0 w-full bg-white border-b border-primary-100 shadow-lg transition-max-height duration-300 ease-in-out, opacity duration-300 ease-in-out max-h-0 overflow-hidden opacity-0"
				aria-hidden="true"
			>
				<div class="flex flex-col p-4 space-y-1">
					{NAV_ITEMS.map((item) => (
						<a
						href={item.href}
						aria-current={currentPage === item.href ? 'page' : undefined}
						class={`rounded-lg px-4 py-3 text-base font-medium transition-colors ${
							currentPage === item.href
								? 'bg-primary-50 text-primary-700'
								: 'text-warm-700 hover:bg-warm-100 hover:text-warm-800'
						}`}
					>
						{item.label}
						</a>
					))}
					<div class="pt-3 border-t border-primary-100">
						<a
							href="/donasi"
							class="block w-full text-center rounded-lg bg-primary-700 px-4 py-3 text-base font-semibold text-white hover:bg-primary-800 transition-colors"
						>
							Donasi Sekarang
						</a>
					</div>
				</div>
			</div>
		</header>

		<script>
			const menuButton = document.getElementById('mobile-menu-button');
			const mobileMenu = document.getElementById('mobile-menu');
			const menuIcon = menuButton?.querySelector('.menu-icon');
			const closeIcon = menuButton?.querySelector('.close-icon');

			function getFocusableElements() {
				if (!mobileMenu) return [];
				return Array.from(
					mobileMenu.querySelectorAll('a[href], button:not([disabled])')
				).filter((el) => el instanceof HTMLElement && el.offsetParent !== null) as HTMLElement[];
			}

			function toggleMenu() {
				if (!menuButton || !mobileMenu || !menuIcon || !closeIcon) return;

				const isExpanded = menuButton.getAttribute('aria-expanded') === 'true';
				menuButton.setAttribute('aria-expanded', String(!isExpanded));
				mobileMenu.setAttribute('aria-hidden', String(isExpanded));

				if (!isExpanded) {
					mobileMenu.classList.remove('max-h-0', 'opacity-0');
					mobileMenu.classList.add('max-h-96', 'opacity-100');
					menuIcon.classList.add('hidden');
					closeIcon.classList.remove('hidden');
					// Focus first link for keyboard users
					const firstLink = mobileMenu.querySelector('a');
					if (firstLink instanceof HTMLElement) {
						firstLink.focus();
					}
				} else {
					mobileMenu.classList.remove('max-h-96', 'opacity-100');
					mobileMenu.classList.add('max-h-0', 'opacity-0');
					menuIcon.classList.remove('hidden');
					closeIcon.classList.add('hidden');
					// Return focus to menu button
					menuButton.focus();
				}
			}

			menuButton?.addEventListener('click', toggleMenu);

			// Close on Escape key + focus trap
			document.addEventListener('keydown', (e) => {
				if (!menuButton || menuButton.getAttribute('aria-expanded') !== 'true') return;

				if (e.key === 'Escape') {
					e.preventDefault();
					toggleMenu();
					return;
				}

				// Focus trap inside mobile menu
				if (e.key === 'Tab') {
					const focusables = getFocusableElements();
					if (focusables.length === 0) return;
					const first = focusables[0];
					const last = focusables[focusables.length - 1];
					const active = document.activeElement;

					if (e.shiftKey) {
						if (active === first || !mobileMenu?.contains(active as Node)) {
							e.preventDefault();
							last.focus();
						}
					} else {
						if (active === last || !mobileMenu?.contains(active as Node)) {
							e.preventDefault();
							first.focus();
						}
					}
				}
			});

			// Close when clicking outside
			document.addEventListener('click', (e) => {
				if (
					menuButton?.getAttribute('aria-expanded') === 'true' &&
					!mobileMenu?.contains(e.target as Node) &&
					!menuButton?.contains(e.target as Node)
				) {
					toggleMenu();
				}
			});
		</script>

		<main id="main-content" class="flex-1" tabindex="-1">
			<slot />
	</main>

		<slot name="after-main" />

		<footer class="bg-primary-950 text-white">
				<Container as="div" class="py-6 sm:py-8 lg:py-12">
					<!-- Grid: mobile 1 col, tablet 2 paired cols, desktop 4 cols -->
					<div class="grid gap-5 sm:gap-6 lg:gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 items-start justify-center">
					<!-- Left Pair: About + Kontak (heavy content) -->
					<div class="flex flex-col gap-5 sm:gap-6 lg:contents">
						<!-- About -->
						<div class="min-w-0">
							<h3 class="mb-2 sm:mb-3 text-base sm:text-lg font-bold text-white">{SITE.shortName}</h3>
							<p class="text-sm text-primary-200 leading-relaxed break-words mb-3">
								{SITE.description}
							</p>
							<a href={`mailto:${CONTACT.email}`} class="text-xs sm:text-sm text-primary-300 hover:text-white transition-colors block break-all">
								{CONTACT.email}
							</a>
						</div>
						<!-- Kontak -->
						<div class="min-w-0">
							<h3 class="mb-2 sm:mb-3 text-xs sm:text-sm font-semibold uppercase tracking-wider text-primary-300">Kontak</h3>
							<ul class="space-y-2 text-sm text-primary-200 break-words">
								<li class="break-words">{CONTACT.address.full}</li>
								<li class="flex flex-wrap gap-2">
									<a href={CONTACT.phoneUrl} class="inline-flex items-center gap-1.5 rounded-md bg-primary-900 px-2.5 py-1.5 text-xs sm:text-sm font-medium text-white hover:bg-primary-800 transition-colors">
										<Icon name="phone" size={4} aria-hidden="true" />
										{CONTACT.phone}
									</a>
									<a href={CONTACT.whatsapp} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 rounded-md bg-primary-900 px-2.5 py-1.5 text-xs sm:text-sm font-medium text-white hover:bg-primary-800 transition-colors">
										<Icon name="whatsapp" size={4} aria-hidden="true" />
										WhatsApp
									</a>
									<a href={SOCIAL.linktree.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 rounded-md bg-primary-900 px-2.5 py-1.5 text-xs sm:text-sm font-medium text-white hover:bg-primary-800 transition-colors">
										<Icon name="external-link" size={4} aria-hidden="true" />
										{SOCIAL.linktree.label}
									</a>
								</li>
							</ul>
						</div>
					</div>
					<!-- Right Pair: Navigasi + Social (light content) -->
					<div class="flex flex-col gap-5 sm:grid sm:grid-cols-2 sm:gap-6 lg:contents justify-center">
						<!-- Navigasi -->
						<div class="min-w-0">
							<h3 class="mb-2 sm:mb-3 text-xs sm:text-sm font-semibold uppercase tracking-wider text-primary-300">Navigasi</h3>
							<ul class="grid grid-cols-3 sm:grid-cols-1 lg:grid-cols-2 gap-x-4 gap-y-1.5 text-sm">
								<li><a href="/" aria-current={currentPage === '/' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Beranda</a></li>
								<li><a href="/tentang" aria-current={currentPage === '/tentang' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Tentang Kami</a></li>
								<li><a href="/program" aria-current={currentPage === '/program' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Program</a></li>
								<li><a href="/kegiatan" aria-current={currentPage === '/kegiatan' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Kegiatan</a></li>
								<li><a href="/blog" aria-current={currentPage === '/blog' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Blog</a></li>
								<li><a href="/galeri" aria-current={currentPage === '/galeri' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Galeri</a></li>
								<li><a href="/donasi" aria-current={currentPage === '/donasi' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Donasi</a></li>
								<li><a href="/kontak" aria-current={currentPage === '/kontak' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Kontak</a></li>
								<li><a href="/faq" aria-current={currentPage === '/faq' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">FAQ</a></li>
								<li><a href="/kebijakan-privasi" aria-current={currentPage === '/kebijakan-privasi' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Kebijakan Privasi</a></li>
								<li><a href="/syarat-ketentuan" aria-current={currentPage === '/syarat-ketentuan' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Syarat &amp; Ketentuan</a></li>
							</ul>
						</div>
						<!-- Social -->
						<div class="min-w-0">
							<h3 class="mb-2 sm:mb-3 text-xs sm:text-sm font-semibold uppercase tracking-wider text-primary-300 text-center sm:text-left">Ikuti Kami</h3>
							<!-- Mobile: icon-only horizontal row -->
							<div class="flex flex-wrap justify-center gap-2 text-primary-300 sm:hidden">
								<a href={SOCIAL.facebook.url} target="_blank" rel="noopener noreferrer" class="p-2 rounded-lg hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-950" aria-label={SOCIAL.facebook.ariaLabel}>
									<Icon name="facebook" size={4} aria-hidden="true" />
								</a>
								<a href={SOCIAL.instagram.url} target="_blank" rel="noopener noreferrer" class="p-2 rounded-lg hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-950" aria-label={SOCIAL.instagram.ariaLabel}>
									<Icon name="instagram" size={4} aria-hidden="true" />
								</a>
								<a href={SOCIAL.tiktok.url} target="_blank" rel="noopener noreferrer" class="p-2 rounded-lg hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-950" aria-label={SOCIAL.tiktok.ariaLabel}>
									<Icon name="tiktok" size={4} aria-hidden="true" />
								</a>
								<a href={SOCIAL.youtube.url} target="_blank" rel="noopener noreferrer" class="p-2 rounded-lg hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-950" aria-label={SOCIAL.youtube.ariaLabel}>
									<Icon name="youtube" size={4} aria-hidden="true" />
								</a>
							</div>
							<!-- Tablet+: vertical list with icon + label -->
							<ul class="hidden sm:flex flex-col gap-2 text-sm text-primary-200">
								<li>
									<a href={SOCIAL.facebook.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-950 rounded-md py-1">
										<Icon name="facebook" size={4} class="shrink-0" aria-hidden="true" />
										<span>{SOCIAL.facebook.label}</span>
									</a>
								</li>
								<li>
									<a href={SOCIAL.instagram.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-950 rounded-md py-1">
										<Icon name="instagram" size={4} class="shrink-0" aria-hidden="true" />
										<span>{SOCIAL.instagram.label}</span>
									</a>
								</li>
								<li>
									<a href={SOCIAL.tiktok.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-950 rounded-md py-1">
										<Icon name="tiktok" size={4} class="shrink-0" aria-hidden="true" />
										<span>{SOCIAL.tiktok.label}</span>
									</a>
								</li>
								<li>
									<a href={SOCIAL.youtube.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-950 rounded-md py-1">
										<Icon name="youtube" size={4} class="shrink-0" aria-hidden="true" />
										<span>{SOCIAL.youtube.label}</span>
									</a>
								</li>
							</ul>
						</div>
					</div>
				</div>
				<div class="mt-6 sm:mt-8 border-t border-primary-800 pt-4 sm:pt-5 text-center text-xs sm:text-sm text-primary-400">
					&copy; {new Date().getFullYear()} {SITE.name}. Seluruh hak cipta dilindungi.
				</div>
			</Container>
		</footer>
	</body>
</html>
