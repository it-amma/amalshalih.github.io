---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import PageHeader from '../../components/sections/PageHeader.astro';
import Icon from '../../components/ui/Icon.astro';
import MasonryGrid from '../../components/gallery/MasonryGrid.astro';
import Lightbox from '../../components/gallery/Lightbox.astro';
import LikeButton from '../../components/gallery/LikeButton.astro';
import { fetchGalleryBySlug, type GalleryEntry } from '../../data/galleries';

// SSR - Real-time data fetching
export const prerender = false;

interface GalleryImage {
  id: string;
  name: string;
  thumbnailUrl: string;
  fullUrl: string;
  width?: number;
  height?: number;
  createdTime?: string;
}

interface GalleryWithImages extends GalleryEntry {
  images: GalleryImage[];
  totalImages: number;
}

// Get slug from URL
const { slug } = Astro.params;

// Fetch gallery in real-time
let gallery: GalleryWithImages | null = null;

if (slug) {
  try {
    const fetched = await fetchGalleryBySlug(slug);
    if (fetched) {
      gallery = fetched as GalleryWithImages;
    }
  } catch (e) {
    console.error('Error fetching gallery:', e);
  }
}

// Return 404 if gallery not found
if (!gallery) {
  return Astro.redirect('/404');
}

const images: GalleryImage[] = gallery.images || [];

// Group images by date (Google Photos style)
const groupedImages: Record<string, GalleryImage[]> = {};
images.forEach((img: GalleryImage) => {
  const date = img.createdTime 
    ? new Date(img.createdTime).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })
    : 'Lainnya';
  if (!groupedImages[date]) {
    groupedImages[date] = [];
  }
  groupedImages[date].push(img);
});

const dateGroups = Object.entries(groupedImages).sort((a, b) => {
  const dateA = a[1][0]?.createdTime ?? '';
  const dateB = b[1][0]?.createdTime ?? '';
  return dateB.localeCompare(dateA);
});

// SEO Meta Tags
const pageTitle = `${gallery.title} — Galeri ASIB`;
const pageDescription = gallery.description;
const coverImage = images.length > 0 ? images[0].thumbnailUrl.replace('size=400', 'size=800') : undefined;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  currentPage={`/galeri/${gallery.slug}`}
  image={coverImage}
>
  <PageHeader
    label={gallery.category.charAt(0).toUpperCase() + gallery.category.slice(1)}
    title={gallery.title}
    description={gallery.description}
    gradient="r"
  />

  <Container class="pt-4 sm:pt-6 pb-8 sm:pb-16">
    <!-- Like Button and Back to galleries link -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
      <LikeButton gallerySlug={gallery.slug} />
      <a href="/galeri" class="inline-flex items-center gap-2 text-sm text-primary-700 hover:text-primary-800 transition-colors group">
        <Icon name="arrow-left" size={4} class="transition-transform group-hover:-translate-x-1" aria-hidden="true" />
        <span>Kembali ke Galeri</span>
      </a>
    </div>

    <!-- Cover photo: most liked photo or latest added -->
    {images.length > 0 && (
      <div class="relative mb-8 overflow-hidden rounded-xl sm:rounded-2xl bg-warm-100" data-cover-container>
        <img
          src={images[images.length - 1].thumbnailUrl.replace('size=400', 'size=800')}
          alt={images[images.length - 1].name}
          class="w-full aspect-video sm:aspect-[21/9] object-cover"
          data-cover-image
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent" />
        <div class="absolute bottom-4 left-4 right-4 sm:bottom-6 sm:left-6">
          <span class="inline-block rounded-md bg-white/90 px-3 py-1 text-xs font-bold uppercase tracking-wider text-primary-700 shadow-sm backdrop-blur-sm mb-2">
            Foto Pilihan
          </span>
          <p class="text-white text-sm sm:text-base font-medium" data-cover-caption>{images[images.length - 1].name.replace(/\.[^/.]+$/, '').replace(/[_-]/g, ' ')}</p>
        </div>
      </div>
    )}

    {images.length > 0 ? (
      <div class="space-y-8">
        {dateGroups.map(([date, imgs]: [string, GalleryImage[]]) => (
          <section>
            <h2 class="text-lg font-semibold text-warm-900 mb-4 flex items-center gap-2">
              <Icon name="calendar" size={4} aria-hidden="true" />
              <time>{date}</time>
              <span class="text-sm font-normal text-warm-500">({imgs.length} foto)</span>
            </h2>
            <MasonryGrid images={imgs} gallerySlug={gallery.slug} />
          </section>
        ))}
      </div>
    ) : (
      <div class="flex flex-col items-center justify-center py-16 sm:py-24 text-center">
        <div class="mb-3 rounded-full bg-warm-50 p-4 sm:p-6 text-warm-300">
          <Icon name="image" size={10} class="sm:size-16" aria-hidden="true" />
        </div>
        <h2 class="text-lg sm:text-xl font-bold text-warm-900">Belum Ada Foto</h2>
        <p class="mt-2 max-w-xs text-sm sm:text-base text-warm-600">
          Foto dokumentasi untuk kegiatan ini akan segera ditambahkan oleh tim media.
        </p>
        <a href="/galeri" class="mt-6 inline-flex items-center gap-2 rounded-lg bg-primary-700 px-4 py-2 text-sm font-semibold text-white hover:bg-primary-800 transition-colors">
          <Icon name="arrow-left" size={4} aria-hidden="true" />
          <span>Lihat Galeri Lainnya</span>
        </a>
      </div>
    )}
  </Container>

  <Lightbox images={images} />
</BaseLayout>

<script define:vars={{ images, gallery }} is:inline>
(function() {
  const coverImg = document.querySelector('[data-cover-image]');
  const coverCaption = document.querySelector('[data-cover-caption]');
  if (!coverImg) return;

  function updateCover(data) {
    if (!data || typeof data !== 'object') return;

    let maxLikes = -1;
    let mostLikedId = '';

    for (const [photoId, count] of Object.entries(data)) {
      if (typeof count === 'number' && count > maxLikes) {
        maxLikes = count;
        mostLikedId = photoId;
      }
    }

    if (maxLikes <= 0 || !mostLikedId) return;

    const photo = images.find((img) => img.id === mostLikedId);
    if (photo && photo.thumbnailUrl) {
      coverImg.src = photo.thumbnailUrl.replace('size=400', 'size=800');
      coverImg.alt = photo.name;
      if (coverCaption) {
        coverCaption.textContent = photo.name.replace(/\.[^/.]+$/, '').replace(/[_-]/g, ' ');
      }
    }
  }

  // Try to use data from MasonryGrid if already loaded
  if (window.__galleryLikeDataReady && window.__galleryLikeData) {
    updateCover(window.__galleryLikeData);
    return;
  }

  // Wait for MasonryGrid to load data (avoids double fetch and race condition)
  window.addEventListener('galleryLikesLoaded', function(e) {
    updateCover(e.detail);
  }, { once: true });

  // Fallback: if no event after 100ms, fetch independently
  setTimeout(function() {
    if (!window.__galleryLikeDataReady) {
      fetch(`/api/like?slug=${encodeURIComponent(gallery.slug)}`)
        .then(res => res.json())
        .then(data => updateCover(data))
        .catch(err => console.error('Failed to load most liked photo:', err));
    }
  }, 100);
})();
</script>
