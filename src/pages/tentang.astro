---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import PageHeader from '../components/sections/PageHeader.astro';
import Card from '../components/ui/Card.astro';
import Icon from '../components/ui/Icon.astro';
import { getSiteSettings } from '../lib/sanity/client';
import { SITE, CONTACT } from '../data/site';

// Hybrid: try Sanity first, fall back to local data
let addressFull = CONTACT.address.full;
let addressStreet = CONTACT.address.street;
let phone = CONTACT.phone;
let phoneUrl = CONTACT.phoneUrl;
let email = CONTACT.email;

try {
  const s = await getSiteSettings();
  if (s) {
    if (s.address) {
      addressStreet = s.address.street ?? addressStreet;
      // address.full is not in Sanity — keep local fallback
      addressFull = `${s.address.street ?? CONTACT.address.street}, ${s.address.village ?? CONTACT.address.village}, ${s.address.district ?? CONTACT.address.district}`;
    }
    if (s.phone) phone = s.phone;
    if (s.email) email = s.email;
  }
} catch {
  // Sanity unavailable — use local data silently
}
---

<BaseLayout
	title="Tentang Kami"
	description="Profil Yayasan Amal Shalih Insan Bantul — visi, misi, legalitas, dan struktur organisasi lembaga yang bergerak di bidang pendidikan, sosial, dan keagamaan di Bantul, Yogyakarta."
	currentPage="/tentang"
>
	<PageHeader
		label="Tentang Kami"
		title="Mengenal Yayasan ASIB"
		gradient="tl"
	/>

	<!-- Profil -->
	<Container>
		<div class="grid gap-12 lg:grid-cols-3">
			<div class="lg:col-span-2">
				<h2 class="text-2xl font-bold text-warm-900 sm:text-3xl">Profil Yayasan</h2>
				<div class="mt-6 space-y-4 leading-relaxed text-warm-700">
					<p>
						Yayasan Amal Shalih Insan Bantul (ASIB) adalah organisasi nirlaba yang berdiri sejak
						<strong>{SITE.foundedDate}</strong> berdasarkan SK Kemenkumham RI
						No. {SITE.legal.sk}.
					</p>
					<p>
						Kami memiliki tiga bidang utama: <strong>Pendidikan</strong>, <strong>Sosial Kemanusiaan</strong>, dan
						<strong>Keagamaan</strong>. Untuk mewujudkan program di setiap bidang, kami melibatkan
						seluruh komponen masyarakat sekitar.
					</p>
					<p>
						Berlokasi di {addressFull},
						kami hadir untuk membantu dan mendukung masyarakat kurang mampu, yatim piatu,
						dan dhuafa sebagaimana diajarkan dalam Islam.
					</p>
				</div>
			</div>
			<div>
				<div class="rounded-2xl bg-primary-50 p-8 ring-1 ring-primary-100/50">
					<h3 class="text-lg font-bold text-primary-800">Informasi Legal</h3>
					<dl class="mt-4 space-y-3 text-sm">
						<div>
							<dt class="font-semibold text-warm-800">SK Kemenkumham</dt>
							<dd class="text-warm-700">{SITE.legal.sk}</dd>
						</div>
						<div>
							<dt class="font-semibold text-warm-800">NIB</dt>
							<dd class="text-warm-700">{SITE.legal.nib}</dd>
						</div>
						<div>
							<dt class="font-semibold text-warm-800">NPWP</dt>
							<dd class="text-warm-700">{SITE.legal.npwp}</dd>
						</div>
						<div>
							<dt class="font-semibold text-warm-800">KBLI</dt>
							<dd class="text-warm-700">{SITE.legal.kbli}</dd>
						</div>
					</dl>
				</div>
			</div>
		</div>
	</section>

	<!-- Visi Misi -->
	<section class="bg-warm-50 py-16 ring-1 ring-primary-100/30">
		<Container as="div">
			<div class="grid gap-12 lg:grid-cols-2">
				<!-- Visi -->
				<Card variant="hover" class="p-8">
					<div class="mb-4 icon-box-sm">
						<Icon name="star" size={6} />
					</div>
					<h2 class="text-2xl font-bold text-warm-900">Visi</h2>
					<p class="mt-4 text-lg leading-relaxed text-warm-700">
						&ldquo;Menjadi Lembaga Yang Profesional dan Berkarakter Serta
						<strong class="text-primary-700">Maslahat Bagi Umat</strong>.&rdquo;
					</p>
				</Card>

				<!-- Misi -->
				<Card variant="hover" class="p-8">
					<div class="mb-4 icon-box-sm">
						<Icon name="check-circle" size={6} />
					</div>
					<h2 class="text-2xl font-bold text-warm-900">Misi</h2>
					<ol class="mt-4 space-y-3 text-warm-700">
						<li class="flex gap-3">
							<span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary-100 text-xs font-bold text-primary-700">1</span>
							<span>Menyelenggarakan kegiatan keagamaan, sosial, dan kemanusiaan.</span>
						</li>
						<li class="flex gap-3">
							<span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary-100 text-xs font-bold text-primary-700">2</span>
							<span>Mewujudkan pembinaan yang fokus pada bidang pendidikan dan Tahfiz Al-Qur'an.</span>
						</li>
						<li class="flex gap-3">
							<span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary-100 text-xs font-bold text-primary-700">3</span>
							<span>Melaksanakan penggalangan dan penyaluran donasi untuk semua bidang.</span>
						</li>
						<li class="flex gap-3">
							<span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary-100 text-xs font-bold text-primary-700">4</span>
							<span>Memiliki dan mengembangkan usaha produktif serta menguntungkan.</span>
						</li>
					</ol>
				</Card>
			</div>
		</div>
	</section>

	<!-- Struktur Pengurus -->
	<section class="bg-warm-50 py-16 ring-1 ring-primary-100/30">
		<Container as="div">
			<div class="mb-8 text-center">
				<h2 class="text-3xl font-bold text-warm-900 sm:text-4xl">Struktur Pengurus</h2>
				<p class="mt-3 text-warm-700">Kepengurusan Yayasan Amal Shalih Insan Bantul</p>
			</div>
			<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
				<Card variant="default" class="p-6 text-center">
					<div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary-100 text-primary-600">
						<Icon name="star" size={8} />
					</div>
					<h3 class="font-bold text-warm-900">Pembina</h3>
					<p class="mt-1 text-sm text-warm-700">Dewan Pembina Yayasan</p>
				</Card>
				<Card variant="default" class="p-6 text-center">
					<div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary-100 text-primary-600">
						<Icon name="star" size={8} />
					</div>
					<h3 class="font-bold text-warm-900">Pengawas</h3>
					<p class="mt-1 text-sm text-warm-700">Dewan Pengawas Yayasan</p>
				</Card>
				<Card variant="default" class="p-6 text-center">
					<div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary-100 text-primary-600">
						<Icon name="heart" size={8} />
					</div>
					<h3 class="font-bold text-warm-900">Ketua</h3>
					<p class="mt-1 text-sm text-warm-700">Ketua Yayasan</p>
				</Card>
				<Card variant="default" class="p-6 text-center">
					<div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary-100 text-primary-600">
						<Icon name="book" size={8} />
					</div>
					<h3 class="font-bold text-warm-900">Sekretaris</h3>
					<p class="mt-1 text-sm text-warm-700">Sekretaris Yayasan</p>
				</Card>
				<Card variant="default" class="p-6 text-center">
					<div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary-100 text-primary-600">
						<Icon name="credit-card" size={8} />
					</div>
					<h3 class="font-bold text-warm-900">Bendahara</h3>
					<p class="mt-1 text-sm text-warm-700">Bendahara Yayasan</p>
				</Card>
				<Card variant="default" class="p-6 text-center">
					<div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary-100 text-primary-600">
						<Icon name="book" size={8} />
					</div>
					<h3 class="font-bold text-warm-900">Kepala Program</h3>
					<p class="mt-1 text-sm text-warm-700">Koordinator Program Yayasan</p>
				</Card>
			</div>
			<p class="mt-8 text-center text-sm text-warm-500">
				Data nama pengurus akan dilengkapi oleh tim yayasan.
			</p>
		</div>
	</section>

	<!-- Kontak -->
	<Container>
		<h2 class="text-2xl font-bold text-warm-900 sm:text-3xl">Hubungi Kami</h2>
		<div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
			<div class="rounded-xl border border-primary-100 bg-white p-6">
				<div class="mb-3 icon-box-sm">
					<Icon name="location" size={5} />
				</div>
				<h3 class="font-semibold text-warm-900">Alamat</h3>
				<p class="mt-1 text-sm text-warm-700">
					Juron, Pendowoharjo, Sewon<br />Bantul, DIY 55185
				</p>
			</div>
			<div class="rounded-xl border border-primary-100 bg-white p-6">
				<div class="mb-3 icon-box-sm">
					<Icon name="phone" size={5} />
				</div>
				<h3 class="font-semibold text-warm-900">Telepon/WA</h3>
				<p class="mt-1 text-sm text-warm-700">
					<a href={phoneUrl} class="text-primary-600 hover:underline">{phone}</a>
				</p>
			</div>
			<div class="rounded-xl border border-primary-100 bg-white p-6">
				<div class="mb-3 icon-box-sm">
					<Icon name="email" size={5} />
				</div>
				<h3 class="font-semibold text-warm-900">Email</h3>
				<p class="mt-1 text-sm text-warm-700">
					<a href={`mailto:${email}`} class="text-primary-600 hover:underline break-all">{email}</a>
				</p>
			</div>
			<div class="rounded-xl border border-primary-100 bg-white p-6">
				<div class="mb-3 icon-box-sm">
					<Icon name="globe" size={5} />
				</div>
				<h3 class="font-semibold text-warm-900">Website</h3>
				<p class="mt-1 text-sm text-warm-700">
					<a href={SITE.url} class="text-primary-600 hover:underline">{SITE.shortName}</a>
				</p>
			</div>
		</div>
	</Container>
</BaseLayout>
