---
import PageHeader from '../components/sections/PageHeader.astro'
import Button from '../components/ui/Button.astro'
import Card from '../components/ui/Card.astro'
import Container from '../components/ui/Container.astro'
import Icon from '../components/ui/Icon.astro'
import { CONTACT, SITE } from '../data/site'
import BaseLayout from '../layouts/BaseLayout.astro'
import { getPengurus, getSiteSettings } from '../lib/sanity/client'
import type { SanityPengurus } from '../lib/sanity/types'

// Hybrid: try Sanity first, fall back to local data
let addressStreet = CONTACT.address.street
let legalData = {
	foundedDate: SITE.foundedDate,
	sk: SITE.legal.sk,
	nib: SITE.legal.nib,
	npwp: SITE.legal.npwp,
	kbli: SITE.legal.kbli,
}
let visi =
	'Menjadi Lembaga Yang Profesional dan Berkarakter Serta <strong class="text-gold-400">Maslahat Bagi Umat</strong>.'
let misi = [
	'Menyelenggarakan kegiatan keagamaan, sosial, dan kemanusiaan.',
	"Mewujudkan pembinaan yang fokus pada bidang pendidikan dan Tahfiz Al-Qur'an.",
	'Melaksanakan penggalangan dan penyaluran donasi untuk semua bidang.',
	'Memiliki dan mengembangkan usaha produktif serta menguntungkan.',
]
let pengurus: SanityPengurus[] = []

try {
	const s = await getSiteSettings()
	if (s) {
		if (s.address) {
			addressStreet = s.address.street ?? addressStreet
		}
		if (s.visi) visi = s.visi
		if (s.misi && s.misi.length > 0) misi = s.misi
		if (s.legal) {
			legalData = {
				foundedDate: s.legal.foundedDate ?? legalData.foundedDate,
				sk: s.legal.sk ?? legalData.sk,
				nib: s.legal.nib ?? legalData.nib,
				npwp: s.legal.npwp ?? legalData.npwp,
				kbli: s.legal.kbli ?? legalData.kbli,
			}
		}
	}
} catch (error) {
	console.error('[Tentang] Sanity siteSettings fetch failed:', error)
}

try {
	const p = await getPengurus()
	if (p && p.length > 0) pengurus = p
} catch (error) {
	console.error('[Tentang] Sanity pengurus fetch failed:', error)
}
---

<BaseLayout
	title="Tentang Kami"
	description="Profil Yayasan Amal Shalih Insan Bantul — visi, misi, legalitas, dan struktur organisasi lembaga yang bergerak di bidang pendidikan, sosial, dan keagamaan di Bantul, Yogyakarta."
	currentPage="/tentang"
>
	<PageHeader
		label="Tentang Kami"
		title="Mengenal Yayasan ASIB"
		gradient="tl"
	/>

	<Container class="py-12 sm:py-20 space-y-6 md:space-y-12">
		<!-- Profil Yayasan -->
		<section>
			<!-- Mobile Accordion -->
			<details open class="md:hidden group rounded-2xl bg-white shadow-sm border border-warm-100 open:border-primary-200 transition-all duration-200">
				<summary class="accordion-summary flex cursor-pointer items-center justify-between p-5 sm:p-6 font-semibold text-warm-900 select-none">
					<span class="flex items-center gap-3">
						<span class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-50 text-primary-700 shrink-0">
							<Icon name="book" size={5} />
						</span>
						<span class="text-base">Profil Yayasan</span>
					</span>
					<svg class="w-5 h-5 text-warm-400 shrink-0 transition-transform duration-300 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
					</svg>
				</summary>
				<div class="accordion-reveal px-5 sm:px-6 pb-5 sm:pb-6 space-y-5 text-warm-700 text-sm">
					<p>Yayasan Amal Shalih Insan Bantul (ASIB) adalah organisasi nirlaba yang berdiri sejak <strong>{legalData.foundedDate}</strong> berdasarkan SK Kemenkumham RI No. {legalData.sk}.</p>
					<p>Kami memiliki tiga bidang utama: <strong>Pendidikan</strong>, <strong>Sosial Kemanusiaan</strong>, dan <strong>Keagamaan</strong>.</p>
					<div class="bg-primary-50 p-4 rounded-xl space-y-2">
						<p><strong>SK:</strong> {legalData.sk}</p>
						<p><strong>NIB:</strong> {legalData.nib}</p>
						<p><strong>NPWP:</strong> {legalData.npwp}</p>
						<p><strong>KBLI:</strong> {legalData.kbli}</p>
					</div>
				</div>
			</details>

			<!-- Desktop Expanded -->
			<div class="hidden md:grid lg:grid-cols-3 gap-12 items-start">
				<div class="lg:col-span-2 space-y-6">
					<div class="flex items-center gap-3 mb-2">
						<Icon name="book" size={6} class="text-primary-700" />
						<h2 class="text-3xl sm:text-4xl font-bold text-warm-900 tracking-tight">Profil Yayasan</h2>
					</div>
					<div class="space-y-4 leading-relaxed text-warm-700 text-lg">
						<p>
							Yayasan Amal Shalih Insan Bantul (ASIB) adalah organisasi nirlaba yang berdiri sejak
							<strong>{legalData.foundedDate}</strong> berdasarkan SK Kemenkumham RI
							No. {legalData.sk}.
						</p>
						<p>
							Kami memiliki tiga bidang utama: <strong>Pendidikan</strong>, <strong>Sosial Kemanusiaan</strong>, dan <strong>Keagamaan</strong>. Untuk mewujudkan program di setiap bidang, kami melibatkan seluruh komponen masyarakat sekitar.
						</p>
					</div>
				</div>
				
				<div class="bg-primary-900 text-white rounded-2xl p-6 sm:p-8 shadow-xl">
					<h3 class="text-xl font-bold text-gold-400 mb-6">Informasi Legal</h3>
					<dl class="space-y-4 text-sm">
						<div><dt class="text-primary-300">SK Kemenkumham</dt><dd class="font-semibold text-white">{legalData.sk}</dd></div>
						<div><dt class="text-primary-300">NIB</dt><dd class="font-semibold text-white">{legalData.nib}</dd></div>
						<div><dt class="text-primary-300">NPWP</dt><dd class="font-semibold text-white">{legalData.npwp}</dd></div>
						<div><dt class="text-primary-300">KBLI</dt><dd class="font-semibold text-white">{legalData.kbli}</dd></div>
					</dl>
				</div>
			</div>
		</section>

		<!-- Visi & Misi -->
		<section>
			<!-- Mobile Accordion -->
			<details class="md:hidden group rounded-2xl bg-white shadow-sm border border-warm-100 open:border-primary-200 transition-all duration-200">
				<summary class="accordion-summary flex cursor-pointer items-center justify-between p-5 sm:p-6 font-semibold text-warm-900 select-none">
					<span class="flex items-center gap-3">
						<span class="flex h-10 w-10 items-center justify-center rounded-lg bg-gold-50 text-gold-600 shrink-0">
							<Icon name="star" size={5} />
						</span>
						<span class="text-base">Visi & Misi</span>
					</span>
					<svg class="w-5 h-5 text-warm-400 shrink-0 transition-transform duration-300 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
					</svg>
				</summary>
				<div class="accordion-reveal px-5 sm:px-6 pb-5 sm:pb-6 space-y-6">
					<div class="bg-primary-50 rounded-xl p-5">
						<h3 class="font-bold text-primary-800 mb-2 flex items-center gap-2">
							<span class="flex h-6 w-6 items-center justify-center rounded-full bg-primary-200 text-primary-800 text-xs font-bold">V</span>
							Visi
						</h3>
						<p class="text-warm-700 italic leading-relaxed" set:html={`&ldquo;${visi}&rdquo;`} />
					</div>
					<div>
						<h3 class="font-bold text-primary-800 mb-3 flex items-center gap-2">
							<span class="flex h-6 w-6 items-center justify-center rounded-full bg-gold-200 text-gold-800 text-xs font-bold">M</span>
							Misi
						</h3>
						<ul class="text-warm-700 space-y-2 text-sm">
							{misi.map((item, i) => (
								<li class="flex gap-2">
									<span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary-100 text-primary-700 text-xs font-bold mt-0.5">{i + 1}</span>
									{item}
								</li>
							))}
						</ul>
					</div>
				</div>
			</details>

			<!-- Desktop Expanded -->
			<div class="hidden md:block">
				<div class="flex items-center gap-3 mb-10">
					<Icon name="star" size={6} class="text-gold-500" />
					<h2 class="text-3xl sm:text-4xl font-bold text-warm-900 tracking-tight">Visi & Misi</h2>
				</div>
				<div class="grid lg:grid-cols-2 gap-8">
					<div class="rounded-xl sm:rounded-2xl p-8 sm:p-10 bg-primary-700 text-white shadow-lg">
						<h3 class="text-2xl font-bold mb-4 text-gold-400">Visi</h3>
						<p class="text-xl italic leading-relaxed" set:html={`&ldquo;${visi}&rdquo;`} />
					</div>
					<Card variant="default" class="p-8 sm:p-10 border-warm-200">
						<h3 class="text-2xl font-bold mb-6 text-primary-800">Misi</h3>
						<ol class="space-y-4 text-warm-700">
							{misi.map((item, i) => (
								<li class="flex gap-4">
									<span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-primary-100 font-bold text-primary-800">{i + 1}</span>
									<span class="text-lg">{item}</span>
								</li>
							))}
						</ol>
					</Card>
				</div>
			</div>
		</section>

		<!-- Struktur Pengurus -->
		<section>
			<!-- Mobile Accordion -->
			<details class="md:hidden group rounded-2xl bg-white shadow-sm border border-warm-100 open:border-primary-200 transition-all duration-200">
				<summary class="accordion-summary flex cursor-pointer items-center justify-between p-5 sm:p-6 font-semibold text-warm-900 select-none">
					<span class="flex items-center gap-3">
						<span class="flex h-10 w-10 items-center justify-center rounded-lg bg-red-50 text-red-500 shrink-0">
							<Icon name="heart" size={5} />
						</span>
						<span class="text-base">Struktur Pengurus</span>
					</span>
					<svg class="w-5 h-5 text-warm-400 shrink-0 transition-transform duration-300 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
					</svg>
				</summary>
				<div class="accordion-reveal px-5 sm:px-6 pb-5 sm:pb-6 space-y-3 text-sm text-warm-700">
					{pengurus.length > 0 ? (
						<div class="divide-y divide-warm-100">
							{pengurus.map(p => 
								<div class="py-3 first:pt-0 last:pb-0">
									<p class="font-bold text-warm-900">{p.name}</p>
									<p class="text-primary-700 text-xs font-medium mt-0.5">{p.position}</p>
									{p.description && <p class="text-xs text-warm-500 mt-1">{p.description}</p>}
								</div>
							)}
						</div>
					) : (
						<p class="italic text-warm-500 text-center py-4">Struktur pengurus akan segera diperbarui.</p>
					)}
				</div>
			</details>

			<!-- Desktop Expanded -->
			<div class="hidden md:block">
				<div class="flex items-center gap-3 mb-10">
					<Icon name="heart" size={6} class="text-primary-700" />
					<h2 class="text-3xl sm:text-4xl font-bold text-warm-900 tracking-tight">Struktur Pengurus</h2>
				</div>
				<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
					{pengurus.length > 0 ? pengurus.map((p) => (
						<Card variant="default" class="p-6 text-center border-warm-100 hover:shadow-lg transition-shadow">
							{p.photoUrl ? (
								<img src={p.photoUrl} alt={p.photoAlt ?? p.name} class="mx-auto mb-4 h-20 w-20 rounded-full object-cover border-2 border-primary-100" />
							) : (
								<div class="mx-auto mb-4 flex h-20 w-20 items-center justify-center rounded-full bg-primary-50 text-primary-700">
									<Icon name="star" size={10} />
								</div>
							)}
							<h3 class="text-lg font-bold text-warm-900">{p.name}</h3>
							<p class="mt-1 text-sm text-primary-700 font-semibold">{p.position}</p>
							{p.description && <p class="mt-2 text-xs text-warm-500">{p.description}</p>}
						</Card>
					)) : (
						<p class="col-span-full text-center text-warm-500 italic">Struktur pengurus akan segera diperbarui.</p>
					)}
				</div>
			</div>
		</section>
	</Container>

	<Fragment slot="after-main">
		<!-- Geometric Lattice — diamond chains & 8-pointed star bursts, structural & organic -->
		<section class="relative overflow-hidden bg-gradient-to-b from-primary-800 via-primary-900 to-primary-950 text-white">
			<!-- Soft side glow -->
			<div class="absolute top-1/2 left-0 h-32 w-32 -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary-600/15 blur-3xl" aria-hidden="true"></div>
			<div class="absolute top-1/3 right-0 h-40 w-40 translate-x-1/3 rounded-full bg-gold-500/8 blur-3xl" aria-hidden="true"></div>

			<!-- Diamond chain cascade — flowing diagonally from top-left to center -->
			<div class="absolute top-4 left-[8%] w-2 h-2 rotate-45 rounded-[1px] bg-gold-400/30" aria-hidden="true"></div>
			<div class="absolute top-7 left-[11%] w-1.5 h-1.5 rotate-45 rounded-[1px] bg-gold-400/20" aria-hidden="true"></div>
			<div class="absolute top-11 left-[9%] w-2 h-2 rotate-45 rounded-[1px] bg-white/15" aria-hidden="true"></div>
			<div class="absolute top-14 left-[13%] w-1.5 h-1.5 rotate-45 rounded-[1px] bg-gold-400/20" aria-hidden="true"></div>
			<div class="absolute top-18 left-[11%] w-2 h-2 rotate-45 rounded-[1px] bg-gold-400/25" aria-hidden="true"></div>

			<!-- Another diamond chain — top-right arc -->
			<div class="absolute top-5 right-[10%] w-1.5 h-1.5 rotate-45 rounded-[1px] bg-white/15" aria-hidden="true"></div>
			<div class="absolute top-9 right-[13%] w-2 h-2 rotate-45 rounded-[1px] bg-gold-400/25" aria-hidden="true"></div>
			<div class="absolute top-13 right-[11%] w-1.5 h-1.5 rotate-45 rounded-[1px] bg-gold-400/20" aria-hidden="true"></div>
			<div class="absolute top-17 right-[15%] w-2 h-2 rotate-45 rounded-[1px] bg-white/12" aria-hidden="true"></div>

			<!-- 8-pointed star burst — intersection of two diamonds -->
			<div class="absolute top-8 left-[22%]" aria-hidden="true">
				<div class="absolute w-3 h-3 rotate-45 bg-gold-400/20 rounded-[1px]"></div>
				<div class="absolute w-3 h-3 bg-gold-400/15 rounded-[1px]"></div>
			</div>
			<div class="absolute top-10 right-[22%]" aria-hidden="true">
				<div class="absolute w-2.5 h-2.5 rotate-45 bg-white/10 rounded-[1px]"></div>
				<div class="absolute w-2.5 h-2.5 bg-white/8 rounded-[1px]"></div>
			</div>
			<div class="absolute bottom-16 left-[18%]" aria-hidden="true">
				<div class="absolute w-2 h-2 rotate-45 bg-gold-400/18 rounded-[1px]"></div>
				<div class="absolute w-2 h-2 bg-gold-400/12 rounded-[1px]"></div>
			</div>
			<div class="absolute bottom-10 right-[25%]" aria-hidden="true">
				<div class="absolute w-3 h-3 rotate-45 bg-gold-400/15 rounded-[1px]"></div>
				<div class="absolute w-3 h-3 bg-white/8 rounded-[1px]"></div>
			</div>

			<!-- Bottom scattered diamonds — like falling geometric debris -->
			<div class="absolute bottom-8 left-[30%] w-1.5 h-1.5 rotate-45 rounded-[1px] bg-gold-400/20" aria-hidden="true"></div>
			<div class="absolute bottom-12 left-[35%] w-2 h-2 rotate-45 rounded-[1px] bg-white/10" aria-hidden="true"></div>
			<div class="absolute bottom-6 right-[18%] w-2 h-2 rotate-45 rounded-[1px] bg-gold-400/18" aria-hidden="true"></div>
			<div class="absolute bottom-14 right-[14%] w-1.5 h-1.5 rotate-45 rounded-[1px] bg-gold-400/15" aria-hidden="true"></div>
			<div class="absolute bottom-10 right-[32%] w-2 h-2 rotate-45 rounded-[1px] bg-white/8" aria-hidden="true"></div>

			<!-- Thin connecting lines between some diamonds — subtle lattice feel -->
			<div class="absolute top-[38px] left-[9.5%] h-[14px] w-px bg-gradient-to-b from-gold-400/15 to-transparent rotate-12" aria-hidden="true"></div>
			<div class="absolute top-[66px] left-[10.5%] h-[12px] w-px bg-gradient-to-b from-white/10 to-transparent -rotate-6" aria-hidden="true"></div>
			<div class="absolute top-[46px] right-[11.5%] h-[16px] w-px bg-gradient-to-b from-gold-400/12 to-transparent -rotate-8" aria-hidden="true"></div>

			<Container as="div" class="relative z-10 py-5 sm:py-6 lg:py-8 text-center">
				<h2 class="text-xl sm:text-2xl lg:text-3xl font-bold text-white tracking-tight font-display">
					Ingin Tahu Lebih Lanjut?
				</h2>
				<p class="mx-auto mt-2 max-w-xl text-sm sm:text-base text-primary-200/80">
					Hubungi kami untuk pertanyaan, konfirmasi donasi, atau informasi program Yayasan ASIB.
				</p>
				<div class="mt-4 sm:mt-5 flex flex-wrap justify-center gap-3">
					<Button
						variant="gold"
						size="md"
						href="/kontak"
						class="shadow-lg shadow-primary-950/30 hover:shadow-xl hover:shadow-gold-500/20 hover:-translate-y-0.5 transition-all duration-300"
					>
						<Icon name="phone" size={4} aria-hidden="true" />
						Hubungi Kami
					</Button>
					<Button
						variant="outline-light"
						size="md"
						href="/donasi"
						class="border-white/20 bg-white/5 hover:bg-white/10 hover:border-white/30 backdrop-blur-sm transition-all duration-300 hover:-translate-y-0.5"
					>
						Donasi Sekarang
					</Button>
				</div>
			</Container>
		</section>
	</Fragment>
</BaseLayout>

<style is:global>
	.accordion-summary::marker,
	.accordion-summary::-webkit-details-marker {
		display: none;
		content: '';
	}

	@keyframes accordion-reveal {
		from {
			opacity: 0;
			transform: translateY(-6px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.accordion-reveal {
		animation: accordion-reveal 0.25s ease-out;
	}
</style>
