---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import PageHeader from '../components/sections/PageHeader.astro';
import Icon from '../components/ui/Icon.astro';
import Button from '../components/ui/Button.astro';
import { getSiteSettings } from '../lib/sanity/client';
import { CONTACT, SITE } from '../data/site';

// Hybrid: try Sanity first, fall back to local data
let address = { ...CONTACT.address };
let phone = CONTACT.phone;
let phoneUrl = CONTACT.phoneUrl;
let whatsapp = CONTACT.whatsapp;
let email = CONTACT.email;
let mapsUrl = CONTACT.address.mapsUrl;
let hours = { ...CONTACT.hours };

try {
  const sanitySettings = await getSiteSettings();
  if (sanitySettings) {
    if (sanitySettings.address) address = { ...address, ...sanitySettings.address };
    if (sanitySettings.phone) phone = sanitySettings.phone;
    if (sanitySettings.email) email = sanitySettings.email;
    if (sanitySettings.mapsUrl) mapsUrl = sanitySettings.mapsUrl;
    // Sanity doesn't store phoneUrl/whatsapp/hours — keep local fallbacks
  }
} catch {
  // Sanity unavailable — use local data silently
}
---

<BaseLayout
	title="Kontak"
	description="Hubungi Yayasan Amal Shalih Insan Bantul — alamat, telepon, email, dan formulir kontak untuk pertanyaan, konfirmasi donasi, atau informasi program."
	currentPage="/kontak"
>
	<PageHeader
		label="Kontak"
		title="Hubungi Kami"
		description="Punya pertanyaan, ingin konfirmasi donasi, atau butuh informasi lebih lanjut? Jangan ragu untuk menghubungi kami."
		gradient="bl"
	/>

	<section class="relative bg-warm-50 overflow-hidden">
		<!-- Subtle textured background watermark — mobile & tablet only, hidden on desktop -->
		<div
			class="absolute inset-0 bg-[url('/images/charity-contact.webp')] bg-cover bg-center opacity-[0.05] lg:hidden pointer-events-none"
			aria-hidden="true"
		></div>

		<Container class="py-8 sm:py-16 relative z-10">
			<div class="grid gap-6 sm:gap-8 lg:grid-cols-5 lg:gap-10">
			<!-- Contact Form — primary action, first on mobile, right column on desktop (60% / 3 cols) -->
			<div class="lg:order-2 lg:col-span-3">
				<div class="rounded-xl sm:rounded-2xl bg-white p-5 sm:p-8 shadow-sm">
					<h2 class="text-xl sm:text-2xl font-bold text-warm-900">Kirim Pesan</h2>
					<p class="mt-1 text-sm text-warm-700">
						Isi formulir di bawah ini dan kami akan merespons secepatnya.
					</p>

					<form
						action="https://formspree.io/f/xldjjnnw"
						method="POST"
						class="mt-5 space-y-4"
					>
						<div class="grid gap-4 sm:gap-5 md:grid-cols-2">
							<div>
								<label for="nama" class="block text-sm font-medium text-warm-700">
									Nama Lengkap <span class="text-red-600">*</span>
								</label>
								<input
									type="text"
									id="nama"
									name="nama"
									required
									aria-required="true"
									autocomplete="name"
									class="mt-1.5 block w-full rounded-lg border border-primary-200 px-4 py-2.5 text-sm text-warm-800 placeholder:text-warm-500 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 transition-colors"
									placeholder="Nama Anda…"
								/>
							</div>
							<div>
								<label for="telepon" class="block text-sm font-medium text-warm-700">
									Nomor Telepon
								</label>
								<input
									type="tel"
									id="telepon"
									name="telepon"
									autocomplete="tel"
									class="mt-1.5 block w-full rounded-lg border border-primary-200 px-4 py-2.5 text-sm text-warm-800 placeholder:text-warm-500 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 transition-colors"
									placeholder="0812-3456-7890…"
								/>
							</div>
						</div>

						<div>
							<label for="email" class="block text-sm font-medium text-warm-700">
								Email <span class="text-red-600">*</span>
							</label>
							<input
								type="email"
								id="email"
								name="email"
								required
								aria-required="true"
								autocomplete="email"
								class="mt-1.5 block w-full rounded-lg border border-primary-200 px-4 py-2.5 text-sm text-warm-800 placeholder:text-warm-500 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 transition-colors"
								placeholder="nama@email.com…"
							/>
						</div>

						<div>
							<label for="subjek" class="block text-sm font-medium text-warm-700">
								Subjek
							</label>
							<select
								id="subjek"
								name="subjek"
								autocomplete="off"
								class="mt-1.5 block w-full rounded-lg border border-primary-200 px-4 py-2.5 text-sm text-warm-800 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 transition-colors"
							>
								<option value="">Pilih subjek pesan</option>
								<option value="donasi">Konfirmasi Donasi</option>
								<option value="program">Informasi Program</option>
								<option value="kerjasama">Kerja Sama</option>
								<option value="pendaftaran">Pendaftaran Santri</option>
								<option value="lainnya">Lainnya</option>
							</select>
						</div>

						<div>
							<label for="pesan" class="block text-sm font-medium text-warm-700">
								Pesan <span class="text-red-600">*</span>
							</label>
							<textarea
								id="pesan"
								name="pesan"
								rows="5"
								required
								aria-required="true"
								class="mt-1.5 block w-full rounded-lg border border-primary-200 px-4 py-2.5 text-sm text-warm-800 placeholder:text-warm-500 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 transition-colors resize-y"
								placeholder="Tulis pesan Anda di sini…"
							></textarea>
						</div>

						<Button variant="primary" class="w-full" type="submit">
							Kirim Pesan
						</Button>
					</form>
				</div>
			</div>

			<!-- Info Cards — secondary, below form on mobile, left column on desktop (40% / 2 cols) -->
			<div class="lg:order-1 lg:col-span-2 space-y-4 sm:space-y-5 md:grid md:grid-cols-2 md:gap-6 md:space-y-0 lg:block lg:space-y-5">
				<!-- Card 1: Featured Image — Islamic charity visual, top of sidebar in desktop, hidden on mobile & tablet -->
				<div class="hidden lg:block rounded-lg sm:rounded-xl bg-white overflow-hidden shadow-sm h-48 sm:h-56 lg:h-64 md:col-span-2 lg:col-span-1 relative">
					<img
						src="/images/charity-contact.webp"
						alt="Tangan memberikan kurma — ilustrasi kebaikan, berbagi, dan kedermawanan dalam Islam"
						class="absolute inset-0 w-full h-full object-cover"
						loading="lazy"
						decoding="async"
					/>
					<div class="absolute inset-0 bg-gradient-to-t from-primary-900/40 to-transparent lg:bg-gradient-to-b lg:from-primary-900/20 lg:to-transparent"></div>
				</div>

				<!-- Card 2: Alamat Kantor -->
				<div class="rounded-lg sm:rounded-xl bg-white p-5 sm:p-8 shadow-sm">
					<div class="mb-2 icon-box-sm">
						<Icon name="location" size={5} aria-hidden="true" />
					</div>
					<h2 class="font-bold text-warm-900 text-base sm:text-lg">Alamat Kantor</h2>
					<p class="mt-1.5 text-sm leading-relaxed text-warm-700">
						{address.street}, {address.village}, {address.district}<br />
						{address.city}, {address.province}<br />
						Kode Pos {address.postalCode}
					</p>
					<a
						href={mapsUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-primary-700 hover:text-primary-800 transition-colors"
					>
						Lihat di Google Maps
						<Icon name="external-link" size={4} aria-hidden="true" />
					</a>
				</div>

				<!-- Card 3: Telepon & WhatsApp -->
				<div class="rounded-lg sm:rounded-xl bg-white p-5 sm:p-8 shadow-sm">
					<div class="mb-2 icon-box-sm">
						<Icon name="phone" size={5} aria-hidden="true" />
					</div>
					<h2 class="font-bold text-warm-900 text-base sm:text-lg">Telepon &amp; WhatsApp</h2>
					<p class="mt-1.5 text-sm text-warm-700">
						<a href={phoneUrl} class="text-primary-700 hover:underline">{phone}</a>
					</p>
					<Button variant="primary" href={whatsapp} class="mt-3 w-full" target="_blank" rel="noopener noreferrer">
						<Icon name="whatsapp" size={4} aria-hidden="true" />
						WhatsApp
					</Button>
				</div>

				<!-- Card 4: Email -->
				<div class="rounded-lg sm:rounded-xl bg-white p-5 sm:p-8 shadow-sm">
					<div class="mb-2 icon-box-sm">
						<Icon name="email" size={5} aria-hidden="true" />
					</div>
					<h2 class="font-bold text-warm-900 text-base sm:text-lg">Email</h2>
					<p class="mt-1.5 text-sm">
						<a href={`mailto:${email}`} class="text-primary-700 break-all hover:underline">
							{email}
						</a>
					</p>
				</div>

				<!-- Card 5: Jam Operasional -->
				<div class="rounded-lg sm:rounded-xl bg-white p-5 sm:p-8 shadow-sm">
					<div class="mb-2 icon-box-sm">
						<Icon name="clock" size={5} aria-hidden="true" />
					</div>
					<h2 class="font-bold text-warm-900 text-base sm:text-lg">Jam Operasional</h2>
					<div class="mt-2.5 space-y-2 text-sm text-warm-700">
						<div class="flex justify-between">
							<span>Senin–Jumat</span>
							<span class="font-medium text-warm-800">{hours.weekdays}</span>
						</div>
						<div class="flex justify-between">
							<span>Sabtu</span>
							<span class="font-medium text-warm-800">{hours.saturday}</span>
						</div>
						<div class="flex justify-between">
							<span>Minggu</span>
							<span class="font-medium text-warm-800">{hours.sunday}</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</Container>
	</section>
</BaseLayout>
