---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/sections/PageHeader.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import Icon from '../components/ui/Icon.astro';
---

<BaseLayout
	title="Program"
	description="Program Yayasan Amal Shalih Insan Bantul — Pendidikan Islam, Keagamaan, dan Sosial Kemanusiaan. PKBM, PAUD, Tahfidz, Wakaf, Santunan, dan banyak lagi."
	currentPage="/program"
>
	<PageHeader
		label="Program"
		title="Program &amp; Kegiatan"
		description="Tiga pilar pengabdian kami: Pendidikan Islam, Keagamaan, dan Sosial Kemanusiaan."
	/>

	<!-- Pendidikan -->
	<section id="pendidikan" class="mx-auto max-w-6xl px-4 py-16">
		<div class="mb-8 flex items-center gap-4">
			<div class="icon-box">
				<Icon name="book" size={7} />
			</div>
			<div>
				<h2 class="text-3xl font-bold text-warm-900">Bidang Pendidikan</h2>
				<p class="mt-1 text-warm-700">Membangun generasi Qur'ani sejak usia dini</p>
			</div>
		</div>

		<div class="grid gap-6 lg:grid-cols-3">
			<Card variant="default" class="p-6">
				<h3 class="text-xl font-bold text-primary-700">PKBM Bina Insan Mulia</h3>
				<span class="mt-2 inline-block rounded-full bg-primary-50 px-3 py-1 text-xs font-medium text-primary-600">Pendidikan Diniyah</span>
				<p class="mt-4 text-sm leading-relaxed text-warm-700">
					Pusat Kegiatan Belajar Masyarakat dengan materi Diniyah untuk mempersiapkan generasi
					milenial yang beraqidah kuat dan berakhlak mulia.
				</p>
				<div class="mt-4 grid grid-cols-2 gap-3 text-sm">
					<div class="rounded-lg bg-warm-50 p-3 text-center">
						<p class="font-bold text-primary-600">21</p>
						<p class="text-xs text-warm-700">Ustadz/Ustadzah</p>
					</div>
					<div class="rounded-lg bg-warm-50 p-3 text-center">
						<p class="font-bold text-primary-600">70</p>
						<p class="text-xs text-warm-700">Santri</p>
					</div>
				</div>
			</Card>

			<Card variant="default" class="p-6">
				<h3 class="text-xl font-bold text-primary-700">PAUD Bina Tunas Mulia</h3>
				<span class="mt-2 inline-block rounded-full bg-primary-50 px-3 py-1 text-xs font-medium text-primary-600">Usia 1–6 Tahun</span>
				<p class="mt-4 text-sm leading-relaxed text-warm-700">
					Program pendidikan non-formal untuk taman pengasuhan anak dan kelompok bermain.
					Membuka layanan untuk anak usia 1 hingga 6 tahun.
				</p>
				<div class="mt-4 grid grid-cols-2 gap-3 text-sm">
					<div class="rounded-lg bg-warm-50 p-3 text-center">
						<p class="font-bold text-primary-600">4</p>
						<p class="text-xs text-warm-700">Guru</p>
					</div>
					<div class="rounded-lg bg-warm-50 p-3 text-center">
						<p class="font-bold text-primary-600">8</p>
						<p class="text-xs text-warm-700">Siswa</p>
					</div>
				</div>
			</Card>

			<Card variant="default" class="p-6">
				<h3 class="text-xl font-bold text-primary-700">Rumah Tahfidz</h3>
				<span class="mt-2 inline-block rounded-full bg-primary-50 px-3 py-1 text-xs font-medium text-primary-600">Tahfidz &amp; Tahsin</span>
				<p class="mt-4 text-sm leading-relaxed text-warm-700">
					Pesantren tahfidz yang diselenggarakan di kantor yayasan. Program tahfidz dan tahsin
					Al-Qur'an bagi para santriwati dengan bimbingan ustadzah berpengalaman.
				</p>
				<div class="mt-4 grid grid-cols-2 gap-3 text-sm">
					<div class="rounded-lg bg-warm-50 p-3 text-center">
						<p class="font-bold text-primary-600">2</p>
						<p class="text-xs text-warm-700">Ustadzah</p>
					</div>
					<div class="rounded-lg bg-warm-50 p-3 text-center">
						<p class="font-bold text-primary-600">25</p>
						<p class="text-xs text-warm-700">Santriwati</p>
					</div>
				</div>
			</Card>
		</div>
	</section>

	<!-- Keagamaan -->
	<section id="keagamaan" class="bg-warm-50 ring-1 ring-primary-100/30">
		<div class="mx-auto max-w-6xl px-4 py-16">
			<div class="mb-8 flex items-center gap-4">
				<div class="icon-box">
					<Icon name="home" size={7} />
				</div>
				<div>
					<h2 class="text-3xl font-bold text-warm-900">Bidang Keagamaan</h2>
					<p class="mt-1 text-warm-700">Memperkuat iman dan ibadah umat</p>
				</div>
			</div>

			<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
				<Card variant="default" class="p-6">
					<h3 class="font-bold text-warm-900">Wakaf Lahan Tahfidz</h3>
					<p class="mt-2 text-sm leading-relaxed text-warm-700">
						Penggalangan wakaf jariyah untuk pengadaan lahan 2.000 m² guna pembangunan
						Pesantren Tahfidz dan Madrasah.
					</p>
				</Card>
				<Card variant="default" class="p-6">
					<h3 class="font-bold text-warm-900">Qurban</h3>
					<p class="mt-2 text-sm leading-relaxed text-warm-700">
						Penerimaan dan penyaluran daging qurban kepada yatim, dhuafa, dan masyarakat
						yang membutuhkan di Bantul dan sekitarnya.
					</p>
				</Card>
				<Card variant="default" class="p-6">
					<h3 class="font-bold text-warm-900">Zakat, Infaq &amp; Shadaqah</h3>
					<p class="mt-2 text-sm leading-relaxed text-warm-700">
						Menerima dan menyalurkan ZIS kepada mustahiq yang berhak. Termasuk zakat fitrah
						pada bulan Ramadhan.
					</p>
				</Card>
				<Card variant="default" class="p-6">
					<h3 class="font-bold text-warm-900">Kafarat</h3>
					<p class="mt-2 text-sm leading-relaxed text-warm-700">
						Layanan pembayaran kafarat sesuai syariat Islam bagi masyarakat yang membutuhkan.
					</p>
				</Card>
				<Card variant="default" class="p-6">
					<h3 class="font-bold text-warm-900">Hari Besar Islam</h3>
					<p class="mt-2 text-sm leading-relaxed text-warm-700">
						Maulid Bersedekah, Nuzulul Qur'an, Syawalan, Bazar &amp; Buka Puasa Bersama,
						serta berbagai peringatan hari besar Islam.
					</p>
				</Card>
				<Card variant="default" class="p-6">
					<h3 class="font-bold text-warm-900">Pesantren Ramadhan</h3>
					<p class="mt-2 text-sm leading-relaxed text-warm-700">
						Program intensif bulan Ramadhan meliputi pengajian, buka puasa bersama,
						sholat berjamaah, tahfidz, dan wisuda Juz 30.
					</p>
				</Card>
			</div>
		</div>
	</section>

	<!-- Sosial -->
	<section id="sosial" class="mx-auto max-w-6xl px-4 py-16">
		<div class="mb-8 flex items-center gap-4">
			<div class="icon-box">
				<Icon name="heart" size={7} />
			</div>
			<div>
				<h2 class="text-3xl font-bold text-warm-900">Bidang Sosial Kemanusiaan</h2>
				<p class="mt-1 text-warm-700">Meringankan beban saudara-saudara kita</p>
			</div>
		</div>

		<div class="grid gap-6 lg:grid-cols-3">
			<Card variant="overflow">
				<div class="bg-primary-600 p-4 text-white">
					<h3 class="text-lg font-bold text-white">Santunan Sembako Bulanan</h3>
				</div>
				<div class="p-6">
					<div class="mb-3 text-3xl font-extrabold text-primary-600">110</div>
					<p class="text-sm text-warm-700">Penerima binaan tetap</p>
					<p class="mt-3 text-sm leading-relaxed text-warm-700">
						Santunan untuk anak yatim, fakir miskin, dan dhuafa dalam bentuk sembako
						yang disalurkan <strong>setiap bulan</strong>. Program ini telah meringankan
						beban ekonomi masyarakat, terutama yang terdampak Covid-19.
					</p>
				</div>
			</Card>

			<Card variant="overflow">
				<div class="bg-primary-600 p-4 text-white">
					<h3 class="text-lg font-bold text-white">Jumat Bersedekah</h3>
				</div>
				<div class="p-6">
					<div class="mb-3 text-3xl font-extrabold text-primary-600" aria-hidden="true">🗓️</div>
					<p class="text-sm text-warm-700">Setiap Hari Jumat</p>
					<p class="mt-3 text-sm leading-relaxed text-warm-700">
						Pembagian <strong>nasi kotak</strong> kepada dhuafa — tukang becak, pemulung,
						pengemis, dan kaum yang membutuhkan di sepanjang jalan wilayah Yogyakarta.
					</p>
				</div>
			</Card>

			<Card variant="overflow">
				<div class="bg-primary-600 p-4 text-white">
					<h3 class="text-lg font-bold text-white">Sedekah Barang Bekas</h3>
				</div>
				<div class="p-6">
					<div class="mb-3 text-3xl font-extrabold text-primary-600" aria-hidden="true">♻️</div>
					<p class="text-sm text-warm-700">Program Barkas</p>
					<p class="mt-3 text-sm leading-relaxed text-warm-700">
						Menerima sedekah berupa <strong>barang bekas layak jual</strong>.
						Kami siap menjemput donasi atau Anda bisa menyetorkan langsung ke kantor.
						Hasil penjualan untuk membiayai kegiatan yayasan.
					</p>
				</div>
			</Card>
		</div>
	</section>

	<!-- CTA -->
	<section class="bg-primary-800 text-white">
		<div class="mx-auto max-w-6xl px-4 py-16 text-center">
			<h2 class="text-3xl font-bold text-white sm:text-4xl">Dukung Program Kami</h2>
			<p class="mx-auto mt-4 max-w-2xl text-lg text-primary-200">
				Setiap donasi Anda, sekecil apapun, berarti besar bagi mereka yang membutuhkan.
			</p>
			<Button variant="gold" size="lg" href="/donasi" class="mt-8">
				Donasi Sekarang
				<Icon name="arrow-right" size={5} />
			</Button>
		</div>
	</section>
</BaseLayout>
