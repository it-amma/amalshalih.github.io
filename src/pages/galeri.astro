---
import PageHeader from '../components/sections/PageHeader.astro'
import Card from '../components/ui/Card.astro'
import Container from '../components/ui/Container.astro'
import Icon from '../components/ui/Icon.astro'
import type { GalleryEntry } from '../data/galleries'
import { fetchAllGalleries, filterPublishedGalleries } from '../data/galleries'
import BaseLayout from '../layouts/BaseLayout.astro'
import { KATEGORI_LABELS } from '../lib/constants'
import { getSiteSettings } from '../lib/sanity/client'

// SSR - Real-time data fetching (Cloudflare Workers compatible)
export const prerender = false

// Direct function call for Cloudflare Workers SSR compatibility
let galleries: GalleryEntry[] = []

try {
	const allGalleries = await fetchAllGalleries()
	galleries = filterPublishedGalleries(allGalleries)
} catch (e: any) {
	console.error('Error fetching galleries:', e?.message || e)
}

const DEFAULT_GRADIENTS: Record<string, string> = {
	pendidikan: 'from-primary-400 to-primary-600',
	keagamaan: 'from-gold-400 to-gold-600',
	sosial: 'from-primary-500 to-gold-500',
	umum: 'from-warm-400 to-warm-600',
}

const DEFAULT_ICONS: Record<string, string> = {
	pendidikan: 'book',
	keagamaan: 'home',
	sosial: 'heart',
	umum: 'globe',
}

// Hybrid: Try Sanity siteSettings for gallery category config
let kategoriGradients: Record<string, string> = DEFAULT_GRADIENTS
let kategoriIcons: Record<string, string> = DEFAULT_ICONS
let kategoriLabels: Record<string, string> = {}

try {
	const ss = await getSiteSettings()
	if (ss?.galleryCategoryGradients && ss.galleryCategoryGradients.length > 0) {
		const merged = { ...DEFAULT_GRADIENTS }
		for (const item of ss.galleryCategoryGradients) {
			if (item.category && item.gradient) merged[item.category] = item.gradient
		}
		kategoriGradients = merged
	}
	if (ss?.galleryCategoryIcons && ss.galleryCategoryIcons.length > 0) {
		const merged = { ...DEFAULT_ICONS }
		for (const item of ss.galleryCategoryIcons) {
			if (item.category && item.icon) merged[item.category] = item.icon
		}
		kategoriIcons = merged
	}
	if (ss?.kategoriLabels) {
		kategoriLabels = { ...KATEGORI_LABELS, ...ss.kategoriLabels }
	}
} catch (error) {
	console.error('[Galeri] Sanity siteSettings fetch failed:', error)
}
---

<BaseLayout
	title="Galeri Dokumentasi"
	description="Dokumentasi foto kegiatan Yayasan Amal Shalih Insan Bantul — pendidikan, keagamaan, sosial kemanusiaan, dan berbagai program yayasan."
	currentPage="/galeri"
>
	<PageHeader
		label="Galeri"
		title="Dokumentasi Kegiatan"
		description="Foto dan dokumentasi kegiatan Yayasan ASIB dalam setiap program dan aktivitas."
		gradient="r"
	/>

	<Container class="pt-4 sm:pt-6 pb-8 sm:pb-16">
		<div class="flex flex-wrap gap-2 justify-center mb-6 sm:mb-8" data-filter-gallery>
			<button class="filter-btn rounded-full bg-primary-700 px-4 py-2 text-xs sm:text-sm sm:px-5 sm:py-2.5 font-semibold text-white shadow-sm sm:shadow-md transition-colors duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2" data-filter="all">Semua</button>
			{Object.entries({ ...KATEGORI_LABELS, ...kategoriLabels }).map(([key, label]) => (
				<button class="filter-btn rounded-full bg-primary-50 px-4 py-2 text-xs sm:text-sm sm:px-5 sm:py-2.5 font-semibold text-primary-700 transition-colors duration-300 hover:bg-primary-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2" data-filter={key}>{label}</button>
			))}
		</div>

		<div class="grid gap-5 sm:gap-6 lg:gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3" id="gallery-grid">
			{galleries.map((gallery) => {
				const coverPhoto = gallery.images && gallery.images.length > 0
					? gallery.images[0]
					: null;
				const coverThumbUrl = coverPhoto
					? coverPhoto.thumbnailUrl.replace('size=400', 'size=600')
					: null;

				return (
				<div class="gallery-item transition-all duration-500 ease-out" data-kategori={gallery.category}>
					<Card variant="hover" href={`/galeri/${gallery.slug}`} class="group !p-0">
						<div class={`relative aspect-[4/3] w-full overflow-hidden rounded-xl sm:rounded-2xl ${coverThumbUrl ? '' : `bg-gradient-to-br ${kategoriGradients[gallery.category] || 'from-primary-400 to-primary-600'}`}`}>
							{coverThumbUrl ? (
								<img
									src={coverThumbUrl}
									alt={gallery.title}
									class="h-full w-full object-cover transition-all duration-700 ease-out group-hover:scale-105"
									data-cover-image={gallery.slug}
									loading="lazy"
									decoding="async"
								/>
							) : (
								<div class="absolute inset-0 flex items-center justify-center">
									<Icon name={(kategoriIcons[gallery.category] ?? 'book') as 'book' | 'home' | 'heart' | 'globe'} size={16} class="text-white/40" aria-hidden="true" />
								</div>
							)}
							
							<!-- Gradient Overlay -->
							<div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-500" />

							<!-- Top: Category & Photo Count -->
							<div class="absolute top-4 left-4 right-4 flex items-start justify-between gap-2">
								<span class="inline-flex items-center gap-1.5 rounded-full bg-white/95 px-3 py-1.5 text-xs font-semibold uppercase tracking-wide text-primary-700 shadow-sm backdrop-blur-sm">
									<Icon name={(kategoriIcons[gallery.category] ?? 'book') as 'book' | 'home' | 'heart' | 'globe'} size={3.5} aria-hidden="true" />
									{kategoriLabels[gallery.category] || KATEGORI_LABELS[gallery.category] || gallery.category}
								</span>
								<span class="inline-flex items-center gap-1 rounded-full bg-black/50 px-2.5 py-1 text-xs font-medium text-white backdrop-blur-sm">
									<Icon name="image" size={3} aria-hidden="true" />
									{gallery.totalImages} foto
								</span>
							</div>

							<!-- Bottom: Date -->
							<div class="absolute bottom-4 left-4 right-4">
								<div class="flex items-center gap-2 text-white/90 text-xs font-medium">
									<Icon name="calendar" size={3.5} aria-hidden="true" />
									<time datetime={gallery.eventDate}>
										{new Date(gallery.eventDate).toLocaleDateString('id-ID', {
											day: 'numeric',
											month: 'long',
											year: 'numeric',
										})}
									</time>
								</div>
							</div>

							<!-- Hover: View Button -->
							<div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300">
								<span class="translate-y-2 group-hover:translate-y-0 transition-transform duration-300 inline-flex items-center gap-2 rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-primary-700 shadow-lg">
									Lihat Galeri
									<Icon name="arrow-right" size={4} aria-hidden="true" />
								</span>
							</div>
						</div>

						<!-- Content Section -->
						<div class="p-5 sm:p-6 bg-white">
							<h2 class="text-lg sm:text-xl font-bold text-warm-900 leading-tight line-clamp-2 group-hover:text-primary-700 transition-colors duration-300">
								{gallery.title}
							</h2>
							<p class="mt-2 text-sm text-warm-600 leading-relaxed line-clamp-2">
								{gallery.description}
							</p>
							
							<!-- Action Link -->
							<div class="mt-4 flex items-center gap-2 text-sm font-semibold text-primary-600 group-hover:text-primary-700 transition-colors">
								<span>Lihat detail</span>
								<Icon name="arrow-right" size={4} class="transition-transform group-hover:translate-x-1" aria-hidden="true" />
							</div>
						</div>
					</Card>
				</div>
			);
		})}
		</div>

		{galleries.length === 0 && (
			<div class="flex flex-col items-center justify-center py-16 sm:py-24 text-center">
				<div class="mb-3 rounded-full bg-warm-50 p-4 sm:p-6 text-warm-300">
					<Icon name="image" size={10} class="sm:size-16" aria-hidden="true" />
				</div>
				<h2 class="text-lg sm:text-xl font-bold text-warm-900">Belum Ada Galeri</h2>
				<p class="mt-2 max-w-xs text-sm sm:text-base text-warm-600">Galeri dokumentasi akan diperbarui secara berkala oleh tim yayasan.</p>
			</div>
		)}
	</Container>
</BaseLayout>

<style>
	.gallery-item.hidden-item {
		display: none;
	}
	
	.gallery-item.fade-out {
		opacity: 0;
		transform: scale(0.9);
	}

	.gallery-item.fade-in {
		opacity: 1;
		transform: scale(1);
	}
</style>

<script is:inline>
(() => {
	const filterRoot = document.querySelector('[data-filter-gallery]');
	if (!filterRoot) return;

	const items = document.querySelectorAll('.gallery-item');
	const buttons = filterRoot.querySelectorAll('.filter-btn');

	buttons.forEach((btn) => {
		btn.addEventListener('click', () => {
			const filter = btn.getAttribute('data-filter');

			buttons.forEach((b) => {
				b.classList.remove('bg-primary-700', 'text-white', 'shadow-md');
				b.classList.add('bg-primary-50', 'text-primary-700', 'hover:bg-primary-100');
			});
			btn.classList.remove('bg-primary-50', 'text-primary-700', 'hover:bg-primary-100');
			btn.classList.add('bg-primary-700', 'text-white', 'shadow-md');

			items.forEach((item) => {
				const category = item.getAttribute('data-kategori');
				const matches = filter === 'all' || category === filter;

				if (matches) {
					item.classList.remove('hidden-item');
					setTimeout(() => {
						item.classList.remove('fade-out');
						item.classList.add('fade-in');
					}, 10);
				} else {
					item.classList.add('fade-out');
					item.classList.remove('fade-in');
					setTimeout(() => {
						if (item.classList.contains('fade-out')) {
							item.classList.add('hidden-item');
						}
					}, 300);
				}
			});
		});
	});
})();

// Update cover images to most liked photos
(function() {
	const covers = document.querySelectorAll('[data-cover-image]');
	if (!covers.length) return;

	covers.forEach((cover) => {
		const slug = cover.getAttribute('data-cover-image');
		if (!slug) return;

		fetch(`/api/like?slug=${encodeURIComponent(slug)}`)
			.then((res) => res.json())
			.then((data) => {
				if (!data || typeof data !== 'object') return;

				let maxLikes = -1;
				let mostLikedId = '';
				for (const [photoId, count] of Object.entries(data)) {
					if (typeof count === 'number' && count > maxLikes) {
						maxLikes = count;
						mostLikedId = photoId;
					}
				}

				if (maxLikes > 0 && mostLikedId) {
					cover.src = '/api/drive-image/' + mostLikedId + '?size=800';
				}
			})
			.catch(() => {});
	});
})();
</script>
