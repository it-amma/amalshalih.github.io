---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Icon from '../components/ui/Icon.astro';
import { STATS } from '../data/site';
import { getSiteSettings } from '../lib/sanity/client';

type StatItem = { number: string; label: string };

let stats: StatItem[] = STATS;

try {
  const sanitySettings = await getSiteSettings();
  if (sanitySettings?.stats && sanitySettings.stats.length > 0) {
    stats = sanitySettings.stats;
  }
} catch {
  // Sanity unavailable — use local fallback
}
---

<BaseLayout
	title="Beranda"
	description="Yayasan Amal Shalih Insan Bantul (ASIB) — Lembaga profesional berkarakter, maslahat bagi umat. Bergerak di bidang pendidikan Islam, sosial kemanusiaan, dan keagamaan."
	currentPage="/"
>
	<!-- Hero -->
	<section class="relative overflow-hidden bg-gradient-to-br from-primary-800 via-primary-700 to-primary-900 text-white">
		<div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNjAiIGhlaWdodD0iNjAiIHZpZXdCb3g9IjAgMCA2MCA2MCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48ZyBmaWxsPSJub25lIiBmaWxsLXJ1bGU9ImV2ZW5vZGQiPjxnIGZpbGw9IiNmZmYiIGZpbGwtb3BhY2l0eT0iMC4wMyI+PGNpcmNsZSBjeD0iMzAiIGN5PSIzMCIgcj0iMiIvPjwvZz48L2c+PC9zdmc+')] opacity-50"></div>
		<div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pt-6 sm:pt-12 lg:pt-16 pb-12 sm:pb-24 lg:pb-32">
			<div class="max-w-3xl">
				<p class="mb-2 sm:mb-4 text-sm font-semibold uppercase tracking-widest text-gold-300">
					<span class="sm:hidden">Amal Shalih Insan Bantul</span>
					<span class="hidden sm:inline">Yayasan Amal Shalih Insan Bantul</span>
				</p>
				<h1 class="mb-3 sm:mb-6 text-3xl font-extrabold leading-tight text-white sm:text-4xl lg:text-6xl">
					Menjadi Lembaga Profesional &amp; Berkarakter,<br />
					<span class="text-gold-300">Maslahat Bagi Umat</span>
				</h1>
				<p class="mb-5 sm:mb-8 max-w-xl text-base leading-relaxed text-primary-100 sm:text-lg">
					Berdiri sejak 2020, kami berkomitmen membuka akses pendidikan Islam berkualitas,
					memberdayakan ekonomi umat, dan menyalurkan bantuan sosial kemanusiaan bagi
					masyarakat Bantul dan sekitarnya.
				</p>
				<div class="flex flex-nowrap items-center gap-2 sm:gap-4">
					<Button variant="gold" href="/donasi">
						<Icon name="heart" size={5} aria-hidden="true" />
						Donasi Sekarang
					</Button>
					<Button variant="outline-light" href="/program">
						Lihat Program
						<Icon name="arrow-right" size={5} aria-hidden="true" />
					</Button>
				</div>
			</div>
		</div>
	</section>

	<!-- Stats -->
	<section class="relative -mt-6 sm:-mt-12 z-10 mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
		<div class="grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-4">
			{stats.map((stat) => (
				<div class="rounded-lg sm:rounded-xl bg-white p-4 sm:p-6 shadow-lg text-center">
					<p class="text-2xl sm:text-3xl font-extrabold text-primary-700 tabular-nums">{stat.number}</p>
					<p class="mt-1 text-sm text-warm-700">{stat.label}</p>
				</div>
			))}
		</div>
	</section>

	<!-- Dampak Nyata -->
	<section class="bg-primary-50/50 py-8 sm:py-16 lg:py-20">
		<Container as="div">
			<div class="grid items-center gap-6 sm:gap-12 md:grid-cols-2">
				<!-- Left: Image — below text on mobile -->
				<div class="overflow-hidden rounded-xl sm:rounded-2xl shadow-xl md:order-2">
					<img 
						src="/dampak-nyata.webp" 
						alt="Dokumentasi Kegiatan Yayasan ASIB" 
						class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
						loading="lazy"
						decoding="async"
						width="800"
						height="600"
					/>
				</div>
				<!-- Right: Content — first on mobile -->
				<div class="md:order-1">
					<h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-warm-900">Dampak Nyata Kami</h2>
					<p class="mt-2 text-base sm:text-lg text-warm-700">
						Dokumentasi kegiatan dan program yang telah kami laksanakan untuk masyarakat Bantul dan sekitarnya.
					</p>
					<div class="mt-5 flex justify-end sm:justify-start">
						<Button variant="primary" href="/galeri">
							Lihat Dokumentasi
							<Icon name="arrow-right" size={5} aria-hidden="true" />
						</Button>
					</div>
				</div>
			</div>
		</Container>
	</section>

	<!-- Program Overview — replicate tab carousel breakout pattern -->
	<Container class="py-8 sm:py-16 lg:py-20 overflow-x-hidden">
		<div class="mb-8 sm:mb-12 text-center">
			<h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-warm-900">Program Unggulan</h2>
			<p class="mt-2 text-warm-700">Tiga pilar utama pengabdian kami untuk umat</p>
		</div>

		<div class="-mx-4 sm:-mx-6 lg:-mx-8 md:mx-0 flex overflow-x-auto snap-x snap-mandatory gap-4 sm:gap-5 md:grid md:grid-cols-3 md:overflow-visible md:snap-none items-start scrollbar-hide px-4 sm:px-6 lg:px-8 md:px-0 py-3 md:py-0 scroll-pl-6 scroll-pr-6 md:scroll-pl-0 md:scroll-pr-0">
			<!-- Pendidikan -->
			<Card variant="hover" class="snap-start shrink-0 w-[72vw] sm:w-auto">
				<div class="mb-2 h-1.5 w-8 rounded-full bg-primary-500" />
				<h3 class="mb-2 text-lg sm:text-xl font-bold text-warm-900">Pendidikan Islam</h3>
				<p class="mb-3 text-sm leading-relaxed text-warm-700">
					PKBM Bina Insan Mulia, PAUD Bina Tunas Mulia, dan Rumah Tahfidz — membina generasi Qur'ani sejak usia dini.
				</p>
				<a href="/program#pendidikan" class="text-sm font-semibold text-primary-700 hover:text-primary-800 transition-colors">
					Selengkapnya →
				</a>
			</Card>

			<!-- Keagamaan -->
			<Card variant="hover" class="snap-start shrink-0 w-[72vw] sm:w-auto">
				<div class="mb-2 h-1.5 w-8 rounded-full bg-gold-500" />
				<h3 class="mb-2 text-lg sm:text-xl font-bold text-warm-900">Keagamaan</h3>
				<p class="mb-3 text-sm leading-relaxed text-warm-700">
					Wakaf lahan Tahfidz 2000m², qurban, zakat fitrah, kafarat, dan peringatan hari besar Islam.
				</p>
				<a href="/program#keagamaan" class="text-sm font-semibold text-primary-700 hover:text-primary-800 transition-colors">
					Selengkapnya →
				</a>
			</Card>

			<!-- Sosial -->
			<Card variant="hover" class="snap-start shrink-0 w-[72vw] sm:w-auto">
				<div class="mb-2 h-1.5 w-8 rounded-full bg-primary-400" />
				<h3 class="mb-2 text-lg sm:text-xl font-bold text-warm-900">Sosial Kemanusiaan</h3>
				<p class="mb-3 text-sm leading-relaxed text-warm-700">
					Santunan sembako bulanan untuk 110 penerima, Jumat Bersedekah, dan program Sedekah Barang Bekas (Barkas).
				</p>
				<a href="/program#sosial" class="text-sm font-semibold text-primary-700 hover:text-primary-800 transition-colors">
					Selengkapnya →
				</a>
			</Card>
		</div>
	</Container>

	<!-- Urgent Appeal -->
	<section class="bg-gradient-to-r from-gold-50 to-primary-50">
		<Container as="div" class="py-8 sm:py-16">
			<div class="overflow-hidden rounded-xl sm:rounded-2xl bg-white shadow-lg">
				<div class="grid md:grid-cols-2">
					<div class="p-5 sm:p-8 lg:p-12">
						<span class="inline-block rounded-full bg-gold-100 px-3 py-1 text-xs font-bold text-gold-700 uppercase tracking-wide">
							Mendesak
						</span>
						<h2 class="mt-3 text-xl sm:text-2xl lg:text-3xl font-bold text-warm-900">
							Wakaf Lahan Rumah Tahfidz
						</h2>
						<p class="mt-3 leading-relaxed text-warm-700">
							Saat ini kegiatan Tahfidz, Taman Anak, dan Kantor Yayasan masih bergabung di rumah kontrakan sempit.
							Kami membutuhkan lahan seluas <strong>2.000 m²</strong> untuk mewujudkan Rumah Tahfidz Al-Qur'an
							yang layak bagi para santri.
						</p>
						<div class="mt-4 sm:mt-6 flex justify-center">
							<Button variant="primary" href="/donasi" class="w-full sm:w-auto">
								Bantu Wakaf Sekarang
								<Icon name="arrow-right" size={5} aria-hidden="true" />
							</Button>
						</div>
					</div>
					<div class="hidden md:flex items-center justify-center bg-primary-600 p-12">
						<div class="text-center text-white">
							<Icon name="book" size={20} class="mx-auto text-gold-300" aria-hidden="true" />
							<p class="mt-4 text-lg font-semibold">&ldquo;Perumpamaan orang yang menginfakkan hartanya di jalan Allah seperti sebutir biji yang menumbuhkan tujuh bulir.&rdquo;</p>
							<p class="mt-2 text-sm text-primary-200">— QS. Al-Baqarah: 261</p>
						</div>
					</div>
				</div>
			</div>
		</Container>
	</section>
</BaseLayout>
