---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Icon from '../components/ui/Icon.astro';
import { STATS } from '../data/site';
import { getSiteSettings } from '../lib/sanity/client';

type StatItem = { number: string; label: string };

let stats: StatItem[] = STATS;

try {
  const sanitySettings = await getSiteSettings();
  if (sanitySettings?.stats && sanitySettings.stats.length > 0) {
    stats = sanitySettings.stats;
  }
} catch {
  // Sanity unavailable — use local fallback
}
---

<BaseLayout
	title="Beranda"
	description="Yayasan Amal Shalih Insan Bantul (ASIB) — Lembaga profesional berkarakter, maslahat bagi umat. Bergerak di bidang pendidikan Islam, sosial kemanusiaan, dan keagamaan."
	currentPage="/"
>
	<!-- Hero -->
	<section class="relative overflow-hidden bg-gradient-to-br from-primary-800 via-primary-700 to-primary-900 text-white">
		<div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNjAiIGhlaWdodD0iNjAiIHZpZXdCb3g9IjAgMCA2MCA2MCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48ZyBmaWxsPSJub25lIiBmaWxsLXJ1bGU9ImV2ZW5vZGQiPjxnIGZpbGw9IiNmZmYiIGZpbGwtb3BhY2l0eT0iMC4wMyI+PGNpcmNsZSBjeD0iMzAiIGN5PSIzMCIgcj0iMiIvPjwvZz48L2c+PC9zdmc+')] opacity-50"></div>
		<div class="relative mx-auto max-w-6xl px-4 pt-4 sm:pt-8 lg:pt-12 pb-20 sm:pb-28 lg:pb-36">
			<div class="max-w-3xl">
				<p class="mb-4 text-sm font-semibold uppercase tracking-widest text-gold-300">
					Yayasan Amal Shalih Insan Bantul
				</p>
				<h1 class="mb-6 text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
					Menjadi Lembaga Profesional &amp; Berkarakter,<br />
					<span class="text-gold-300">Maslahat Bagi Umat</span>
				</h1>
				<p class="mb-8 max-w-xl text-lg leading-relaxed text-primary-100">
					Berdiri sejak 2020, kami berkomitmen membuka akses pendidikan Islam berkualitas,
					memberdayakan ekonomi umat, dan menyalurkan bantuan sosial kemanusiaan bagi
					masyarakat Bantul dan sekitarnya.
				</p>
				<div class="flex flex-wrap gap-4">
					<Button variant="gold" href="/donasi">
						<Icon name="heart" size={5} />
						Donasi Sekarang
					</Button>
					<Button variant="outline-light" href="/program">
						Lihat Program
						<Icon name="arrow-right" size={5} />
					</Button>
				</div>
			</div>
		</div>
	</section>

	<!-- Stats -->
	<section class="relative -mt-10 z-10 mx-auto max-w-6xl px-4">
		<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
			{STATS.map((stat) => (
				<div class="rounded-xl bg-white p-6 shadow-lg ring-1 ring-primary-100/50 text-center">
					<p class="text-3xl font-extrabold text-primary-600">{stat.number}</p>
					<p class="mt-1 text-sm text-warm-700">{stat.label}</p>
				</div>
			))}
		</div>
	</section>

	<!-- Dampak Nyata -->
	<section class="bg-primary-50/50 py-20">
		<Container as="div">
			<div class="grid items-center gap-12 md:grid-cols-2">
				<!-- Left: Image -->
				<div class="overflow-hidden rounded-2xl shadow-xl ring-1 ring-primary-100/50">
					<img 
						src="/dampak-nyata.webp" 
						alt="Dokumentasi Kegiatan Yayasan ASIB" 
						class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
						loading="lazy"
					/>
				</div>
				<!-- Right: Content -->
				<div>
					<div class="mb-4 inline-flex rounded-xl bg-primary-50 p-3 text-primary-600">
						<Icon name="camera" size={7} />
					</div>
					<h2 class="text-3xl font-bold text-warm-900 sm:text-4xl">Dampak Nyata Kami</h2>
					<p class="mt-3 text-lg text-warm-700">
						Dokumentasi kegiatan dan program yang telah kami laksanakan untuk masyarakat Bantul dan sekitarnya.
					</p>
					<div class="mt-8 grid gap-4 sm:grid-cols-2">
						<div class="rounded-xl border border-primary-100 bg-white p-6 text-center shadow-sm">
							<p class="text-3xl font-extrabold text-primary-600">110+</p>
							<p class="mt-1 text-sm text-warm-700">Penerima Manfaat</p>
						</div>
						<div class="rounded-xl border border-primary-100 bg-white p-6 text-center shadow-sm">
							<p class="text-3xl font-extrabold text-primary-600">7</p>
							<p class="mt-1 text-sm text-warm-700">Unit Program</p>
						</div>
					</div>
					<div class="mt-8">
						<Button variant="primary" href="/tentang">
							Lihat Selengkapnya
							<Icon name="arrow-right" size={5} />
						</Button>
					</div>
				</div>
			</div>
		</Container>
	</section>

	<!-- Program Overview -->
	<Container class="py-20">
		<div class="mb-12 text-center">
			<h2 class="text-3xl font-bold text-warm-900 sm:text-4xl">Program Unggulan</h2>
			<p class="mt-3 text-warm-700">Tiga pilar utama pengabdian kami untuk umat</p>
		</div>

		<div class="grid gap-8 md:grid-cols-3">
			<!-- Pendidikan -->
			<Card variant="hover">
				<div class="mb-4 icon-box">
					<Icon name="book" size={7} />
				</div>
				<h3 class="mb-3 text-xl font-bold text-warm-900">Pendidikan Islam</h3>
				<p class="mb-4 text-sm leading-relaxed text-warm-700">
					PKBM Bina Insan Mulia, PAUD Bina Tunas Mulia, dan Rumah Tahfidz — membina generasi Qur'ani sejak usia dini.
				</p>
				<a href="/program#pendidikan" class="text-sm font-semibold text-primary-600 hover:text-primary-700 transition-colors">
					Selengkapnya →
				</a>
			</Card>

			<!-- Keagamaan -->
			<Card variant="hover">
				<div class="mb-4 icon-box">
					<Icon name="home" size={7} />
				</div>
				<h3 class="mb-3 text-xl font-bold text-warm-900">Keagamaan</h3>
				<p class="mb-4 text-sm leading-relaxed text-warm-700">
					Wakaf lahan Tahfidz 2000m², qurban, zakat fitrah, kafarat, dan peringatan hari besar Islam.
				</p>
				<a href="/program#keagamaan" class="text-sm font-semibold text-primary-600 hover:text-primary-700 transition-colors">
					Selengkapnya →
				</a>
			</Card>

			<!-- Sosial -->
			<Card variant="hover">
				<div class="mb-4 icon-box">
					<Icon name="heart" size={7} />
				</div>
				<h3 class="mb-3 text-xl font-bold text-warm-900">Sosial Kemanusiaan</h3>
				<p class="mb-4 text-sm leading-relaxed text-warm-700">
					Santunan sembako bulanan untuk 110 penerima, Jumat Bersedekah, dan program Sedekah Barang Bekas (Barkas).
				</p>
				<a href="/program#sosial" class="text-sm font-semibold text-primary-600 hover:text-primary-700 transition-colors">
					Selengkapnya →
				</a>
			</Card>
		</div>
	</section>

	<!-- Urgent Appeal -->
	<section class="bg-gradient-to-r from-gold-50 to-primary-50">
		<Container as="div" class="py-16">
			<div class="overflow-hidden rounded-2xl bg-white shadow-lg ring-1 ring-primary-100/50">
				<div class="grid md:grid-cols-2">
					<div class="p-8 sm:p-12">
						<span class="inline-block rounded-full bg-gold-100 px-3 py-1 text-xs font-semibold text-gold-700">
							Mendesak
						</span>
						<h2 class="mt-4 text-2xl font-bold text-warm-900 sm:text-3xl">
							Wakaf Lahan Rumah Tahfidz
						</h2>
						<p class="mt-4 leading-relaxed text-warm-700">
							Saat ini kegiatan Tahfidz, Taman Anak, dan Kantor Yayasan masih bergabung di rumah kontrakan sempit.
							Kami membutuhkan lahan seluas <strong>2.000 m²</strong> untuk mewujudkan Rumah Tahfidz Al-Qur'an
							yang layak bagi para santri.
						</p>
						<Button variant="primary" href="/donasi" class="mt-6">
							Bantu Wakaf Sekarang
							<Icon name="arrow-right" size={5} />
						</Button>
					</div>
					<div class="hidden md:flex items-center justify-center bg-primary-600 p-12">
						<div class="text-center text-white">
							<Icon name="book" size={20} class="mx-auto text-gold-300" />
							<p class="mt-4 text-lg font-semibold">&ldquo;Perumpamaan orang yang menginfakkan hartanya di jalan Allah seperti sebutir biji yang menumbuhkan tujuh bulir.&rdquo;</p>
							<p class="mt-2 text-sm text-primary-200">— QS. Al-Baqarah: 261</p>
						</div>
					</div>
				</div>
			</div>
		</Container>
	</section>

	<!-- CTA Final -->
	<Container class="py-20 text-center">
		<h2 class="text-3xl font-bold text-warm-900 sm:text-4xl">Mari Berbagi Kebaikan</h2>
		<p class="mx-auto mt-4 max-w-2xl text-warm-700">
			Setiap rupiah yang Anda donasikan akan menjadi amal jariyah yang pahalanya terus mengalir.
			Salurkan donasi Anda melalui rekening resmi Yayasan ASIB.
		</p>
		<div class="mt-8 flex flex-wrap justify-center gap-4">
			<Button variant="primary" size="lg" href="/donasi">Donasi Sekarang</Button>
			<Button variant="outline" size="lg" href="/tentang">Tentang Kami</Button>
		</div>
	</Container>
</BaseLayout>
