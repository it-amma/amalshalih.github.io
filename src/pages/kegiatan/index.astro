---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import PageHeader from '../../components/sections/PageHeader.astro';
import Card from '../../components/ui/Card.astro';
import { KATEGORI_LABELS } from '../../lib/constants';
import { getKegiatanList } from '../../lib/sanity/client';

interface kegiatanEntry {
  id: string;
  data: {
    title: string;
    description: string;
    date: Date;
    kategori: string;
  };
}

let kegiatan: kegiatanEntry[] = [];

try {
  const sanityItems = await getKegiatanList();
  if (sanityItems && sanityItems.length > 0) {
    kegiatan = sanityItems.map((item) => ({
      id: item.slug,
      data: {
        title: item.title,
        description: item.excerpt ?? '',
        date: new Date(item.date),
        kategori: item.category,
      },
    }));
  }
} catch {
  // Sanity unavailable
}

if (kegiatan.length === 0) {
  const localItems = await getCollection('kegiatan');
  localItems.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  kegiatan = localItems;
}
---

<BaseLayout
	title="Kegiatan"
	description="Kegiatan dan program terbaru Yayasan Amal Shalih Insan Bantul — berita, laporan, dan dokumentasi program pendidikan, keagamaan, dan sosial."
	currentPage="/kegiatan"
>
	<PageHeader
		label="Kegiatan"
		title="Kegiatan &amp; Berita"
		description="Ikuti kegiatan terbaru dan laporan program Yayasan ASIB."
	/>

	<Container class="py-8 sm:py-16">
		{
			kegiatan.length === 0 ? (
				<div class="text-center py-8 sm:py-16">
					<p class="text-warm-700">Belum ada kegiatan terbaru. Kunjungi kembali nanti.</p>
				</div>
			) : (
				<div class="grid gap-4 sm:gap-6 sm:grid-cols-2 lg:grid-cols-3 items-start">
					{kegiatan.map((item) => (
						<Card variant="hover" href={`/kegiatan/${item.id}`}>
								<div class="mb-3 flex items-center gap-3">
									<span class="inline-block rounded-full bg-primary-50 px-2.5 py-0.5 text-xs font-medium text-primary-700">
										{KATEGORI_LABELS[item.data.kategori] || item.data.kategori}
									</span>
									<time datetime={item.data.date.toISOString()} class="text-xs text-warm-500">
										{item.data.date.toLocaleDateString('id-ID', {
											year: 'numeric',
											month: 'long',
											day: 'numeric',
										})}
									</time>
								</div>
								<h2 class="text-lg font-bold leading-snug text-warm-900 group-hover:text-primary-700 transition-colors">
									{item.data.title}
								</h2>
								<p class="mt-2 text-sm leading-relaxed text-warm-700 line-clamp-2 sm:line-clamp-3">
									{item.data.description}
								</p>
						</Card>
					))}
				</div>
			)
		}
	</Container>
</BaseLayout>
