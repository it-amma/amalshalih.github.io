---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';
import Card from '../../components/ui/Card.astro';
import { KATEGORI_LABELS } from '../../lib/constants';
import { SITE, CONTACT } from '../../data/site';
import { getKegiatanList, getKegiatanItem } from '../../lib/sanity/client';
import { renderPortableText } from '../../lib/sanity/render';

export async function getStaticPaths() {
	const slugs = new Set<string>();

	try {
		const sanityItems = await getKegiatanList();
		for (const item of sanityItems) slugs.add(item.slug);
	} catch {
		// Sanity unavailable
	}

	const localItems = await getCollection('kegiatan');
	for (const item of localItems) slugs.add(item.id);

	return Array.from(slugs).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

type PageData = {
	title: string;
	description: string;
	date: Date;
	kategori: string;
	image?: string;
	fromSanity: boolean;
	bodyHtml: string;
};

let pageData: PageData | null = null;

try {
	const sanityItem = await getKegiatanItem(slug);
	if (sanityItem) {
		pageData = {
			title: sanityItem.title,
			description: sanityItem.excerpt ?? '',
			date: new Date(sanityItem.date),
			kategori: sanityItem.category,
			image: undefined,
			fromSanity: true,
			bodyHtml: renderPortableText(sanityItem.body),
		};
	}
} catch {
	// Sanity unavailable
}

let Content = null;

if (!pageData) {
	const localItems = await getCollection('kegiatan');
	const localItem = localItems.find((item) => item.id === slug);
	if (localItem) {
		const rendered = await render(localItem);
		Content = rendered.Content;
		pageData = {
			title: localItem.data.title,
			description: localItem.data.description,
			date: localItem.data.date,
			kategori: localItem.data.kategori,
			image: localItem.data.image,
			fromSanity: false,
			bodyHtml: '',
		};
	}
}

if (!pageData) {
	return Astro.redirect('/kegiatan');
}

const { title, description, date, kategori, image, fromSanity, bodyHtml } = pageData;

const formattedDate = date.toLocaleDateString('id-ID', {
	weekday: 'long',
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const canonicalUrl = `${SITE.url}/kegiatan/${slug}/`;

// Related articles (exclude current, sort by date desc, take 3)
const allSlugs = new Set<string>();
try {
	const sanityItems = await getKegiatanList();
	for (const item of sanityItems) allSlugs.add(item.slug);
} catch {}
const localAll = await getCollection('kegiatan');
for (const item of localAll) allSlugs.add(item.id);

const relatedSlugs = Array.from(allSlugs).filter((s) => s !== slug).slice(0, 3);

// Build related items data
const relatedItems: { slug: string; title: string; description: string; kategori: string; date: Date }[] = [];

for (const rSlug of relatedSlugs) {
	// Try local first (cheaper)
	const localItem = localAll.find((i) => i.id === rSlug);
	if (localItem) {
		relatedItems.push({
			slug: rSlug,
			title: localItem.data.title,
			description: localItem.data.description,
			kategori: localItem.data.kategori,
			date: localItem.data.date,
		});
	}
}

const shareUrl = encodeURIComponent(canonicalUrl);
const shareTitle = encodeURIComponent(title);

// JSON-LD structured data for Article
const jsonLd = {
	"@context": "https://schema.org",
	"@type": "Article",
	"headline": title,
	"description": description,
	"datePublished": date.toISOString(),
	"dateModified": date.toISOString(),
	"author": {
		"@type": "Organization",
		"name": SITE.name,
		"url": SITE.url
	},
	"publisher": {
		"@type": "Organization",
		"name": SITE.name,
		"url": SITE.url,
		"logo": {
			"@type": "ImageObject",
			"url": `${SITE.url}/logo-yayasan.webp`
		}
	},
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id": canonicalUrl
	},
	"articleSection": KATEGORI_LABELS[kategori] || kategori,
	"keywords": ["yayasan", "amal shalih", "insan bantul", "kegiatan", kategori]
};

// BreadcrumbList JSON-LD
const breadcrumbJsonLd = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{ "@type": "ListItem", "position": 1, "name": "Beranda", "item": SITE.url },
		{ "@type": "ListItem", "position": 2, "name": "Kegiatan", "item": `${SITE.url}/kegiatan/` },
		{ "@type": "ListItem", "position": 3, "name": title, "item": canonicalUrl }
	]
};
---

<BaseLayout
	title={`${title} — Kegiatan Yayasan ASIB`}
	description={description}
	image={image || '/logo-yayasan.webp'}
	pageType="article"
>
	<!-- JSON-LD Structured Data -->
	<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

	<!-- Article-specific OG meta (og:type + og:image handled by BaseHead via pageType + image props) -->
	<meta property="article:published_time" content={date.toISOString()} />
	<meta property="article:section" content={KATEGORI_LABELS[kategori] || kategori} />

	<!-- Hero Section -->
	<div class="relative w-full overflow-hidden bg-gradient-to-b from-primary-900 to-primary-950">
		{image ? (
			<div class="relative">
				<img
					src={image}
					alt={title}
					class="mx-auto h-auto w-full max-w-6xl object-cover opacity-90"
					loading="eager"
					width="1200"
					height="630"
				/>
				<div class="absolute inset-0 bg-gradient-to-t from-primary-950/80 via-primary-950/30 to-transparent" />
			</div>
		) : (
			<div class="mx-auto flex max-w-6xl items-center justify-center py-8 sm:py-20 px-4">
				<div class="text-center">
					<div class="mx-auto mb-4 flex h-16 w-16 sm:h-24 sm:w-24 items-center justify-center rounded-full border-2 border-primary-400/30 bg-primary-800/40 backdrop-blur-sm">
						<Icon name="book" size={10} class="text-primary-300" aria-hidden="true" />
					</div>
					<p class="text-sm font-medium uppercase tracking-widest text-primary-400">Arsip Kegiatan</p>
					<p class="mt-2 text-lg font-semibold text-primary-100">{SITE.shortName}</p>
				</div>
			</div>
		)}
	</div>

	<!-- Article Content -->
	<article class="mx-auto max-w-3xl px-4 sm:px-6" itemscope itemtype="https://schema.org/Article">
		<!-- Breadcrumb Navigation -->
		<nav class="py-4 sm:py-6 text-sm" aria-label="Breadcrumb">
			<ol class="flex items-center gap-2 text-warm-500">
				<li><a href="/" class="hover:text-primary-700 transition-colors">Beranda</a></li>
				<li class="text-warm-400">/</li>
				<li><a href="/kegiatan" class="hover:text-primary-700 transition-colors">Kegiatan</a></li>
				<li class="text-warm-400">/</li>
				<li class="text-warm-700 font-medium" aria-current="page" itemprop="headline">{title}</li>
			</ol>
		</nav>

		<!-- Archival Metadata Bar -->
		<div class="mb-6 flex flex-wrap items-center gap-x-4 gap-y-2 border-b border-warm-200 pb-4">
			<span class="inline-flex items-center gap-1.5 rounded-full border border-primary-200 bg-primary-50 px-3 py-1 text-xs font-semibold text-primary-700">
				<Icon name="check-circle" size={3} class="text-primary-500" aria-hidden="true" />
				{KATEGORI_LABELS[kategori] || kategori}
			</span>
			<time datetime={date.toISOString()} class="text-sm text-warm-500" itemprop="datePublished">
				{formattedDate}
			</time>
			<span class="text-xs text-warm-400">
				Dokumen arsip #{slug}
			</span>
		</div>

		<!-- Title -->
		<h1 class="mb-3 text-2xl font-extrabold leading-tight tracking-tight text-warm-900 sm:text-3xl lg:text-4xl" itemprop="name">
			{title}
		</h1>

		<!-- Lead / Description -->
		<p class="mb-8 text-base leading-relaxed text-warm-600 sm:text-lg" itemprop="description">
			{description}
		</p>

		<!-- Article Body with Prose Typography -->
		<div class="prose prose-warm prose-lg max-w-none
			prose-headings:font-display prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-warm-900
			prose-a:text-primary-700 prose-a:no-underline prose-a:font-medium hover:prose-a:text-primary-700 hover:prose-a:underline
			prose-blockquote:border-l-4 prose-blockquote:border-primary-400 prose-blockquote:bg-primary-50/50 prose-blockquote:px-4 prose-blockquote:py-2.5 prose-blockquote:rounded-r-xl prose-blockquote:not-italic prose-blockquote:text-warm-700 prose-blockquote:leading-relaxed prose-blockquote:font-normal
			prose-img:rounded-xl prose-img:shadow-md
			prose-table:overflow-x-auto prose-table:block prose-table:w-full prose-table:border prose-table:border-warm-200 prose-table:rounded-lg
			prose-thead:bg-primary-50 prose-thead:text-primary-800
			prose-th:px-4 prose-th:py-2 prose-th:text-left prose-th:text-sm prose-th:font-semibold prose-th:uppercase prose-th:tracking-wider
			prose-td:px-4 prose-td:py-2 prose-td:text-sm prose-td:text-warm-700
			prose-tr:border-b prose-tr:border-warm-100
			prose-code:bg-primary-50 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-mono prose-code:text-primary-700
			prose-pre:bg-warm-900 prose-pre:text-warm-100 prose-pre:rounded-xl prose-pre:p-4 prose-pre:overflow-x-auto
			prose-hr:border-warm-200
		">
			{fromSanity ? <div set:html={bodyHtml} /> : Content && <Content />}
		</div>

		<!-- Share & Navigation -->
		<div class="mt-12 flex flex-col items-start gap-4 border-t border-warm-200 pt-6 sm:flex-row sm:items-center sm:justify-between">
			<div class="flex items-center gap-3">
				<span class="text-sm font-medium text-warm-500">Bagikan arsip ini:</span>
				<div class="flex gap-2" data-share-buttons>
					<a
						href={`https://wa.me/?text=${shareTitle}%20${shareUrl}`}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center justify-center rounded-lg bg-green-600 p-3 text-white shadow-sm transition-colors duration-200, shadow duration-200 hover:bg-green-700 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-green-500 focus-visible:ring-offset-2"
						aria-label="Bagikan via WhatsApp"
					>
						<Icon name="whatsapp" size={5} aria-hidden="true" />
					</a>
					<a
						href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center justify-center rounded-lg bg-blue-600 p-3 text-white shadow-sm transition-colors duration-200, shadow duration-200 hover:bg-blue-700 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
						aria-label="Bagikan via Facebook"
					>
						<Icon name="facebook" size={5} aria-hidden="true" />
					</a>
					<button
						type="button"
						data-copy-url={shareUrl}
						class="copy-url-btn inline-flex items-center justify-center rounded-lg bg-warm-600 p-3 text-white shadow-sm transition-colors duration-200, shadow duration-200 hover:bg-warm-700 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-warm-400 focus-visible:ring-offset-2"
						aria-label="Salin tautan"
					>
						<Icon name="external-link" size={5} aria-hidden="true" />
					</button>
				</div>
			</div>
			<a
				href="/kegiatan"
				class="inline-flex items-center gap-1.5 text-sm font-medium text-warm-500 hover:text-primary-700 transition-colors"
			>
				<Icon name="arrow-left" size={4} aria-hidden="true" />
				Kembali ke Daftar Kegiatan
			</a>
		</div>

		<!-- CTA Donasi -->
		<div class="mt-8 relative overflow-hidden rounded-xl sm:rounded-2xl bg-gradient-to-br from-primary-700 to-primary-900 p-5 text-center shadow-xl sm:p-8 lg:p-10">
			<div class="absolute -right-12 -top-12 h-40 w-40 rounded-full bg-white/5" />
			<div class="absolute -bottom-16 -left-16 h-56 w-56 rounded-full bg-white/5" />
			<div class="absolute right-8 top-8 h-2 w-2 rounded-full bg-gold-400/60" />
			<div class="absolute bottom-12 left-12 h-1.5 w-1.5 rounded-full bg-gold-300/40" />

			<div class="relative z-10">
				<div class="mx-auto mb-3 flex h-12 w-12 sm:h-14 sm:w-14 items-center justify-center rounded-full bg-white/15">
					<Icon name="heart" size={7} class="text-gold-300" aria-hidden="true" />
				</div>
				<h2 class="text-xl sm:text-2xl font-bold text-white sm:text-3xl">Dukung Program Kami</h2>
				<p class="mx-auto mt-2 max-w-md text-sm sm:text-base leading-relaxed text-primary-100">
					Setiap donasi Anda membantu kami menjangkau lebih banyak penerima manfaat dan mewujudkan dampak nyata bagi umat.
				</p>
				<div class="mt-4 flex flex-col items-center justify-center gap-3 sm:flex-row sm:mt-6">
					<a
						href="/donasi"
						class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-primary-700 shadow-lg transition-colors duration-200, transform duration-200 hover:bg-primary-50 hover:scale-[1.02] active:scale-95"
					>
						Donasi Sekarang
						<Icon name="arrow-right" size={5} aria-hidden="true" />
					</a>
					<a
						href={CONTACT.whatsapp}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2 rounded-lg border border-white/30 px-5 py-2.5 text-sm font-medium text-white transition-colors duration-200, border-color duration-200 hover:bg-white/10 hover:border-white/50"
					>
						<Icon name="whatsapp" size={5} aria-hidden="true" />
						Hubungi Kami
					</a>
				</div>
			</div>
		</div>

		<!-- Related Articles -->
		{relatedItems.length > 0 && (
			<section class="mt-16 mb-8">
				<h2 class="mb-2 text-2xl font-bold text-warm-900">Arsip Kegiatan Terkait</h2>
				<p class="mb-8 text-sm text-warm-500">Dokumen kegiatan lain yang mungkin relevan</p>
				<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
					{relatedItems.map((related) => (
						<Card variant="hover" href={`/kegiatan/${related.slug}`}>
							<div class="mb-3 flex items-center gap-3">
								<span class="inline-block rounded-full bg-primary-50 px-2.5 py-0.5 text-xs font-medium text-primary-700">
									{KATEGORI_LABELS[related.kategori] || related.kategori}
								</span>
								<time datetime={related.date.toISOString()} class="text-xs text-warm-500">
									{related.date.toLocaleDateString('id-ID', {
										year: 'numeric',
										month: 'long',
										day: 'numeric',
									})}
								</time>
							</div>
							<h3 class="text-base font-bold leading-snug text-warm-900 group-hover:text-primary-700 transition-colors line-clamp-2">
								{related.title}
							</h3>
							<p class="mt-2 text-sm leading-relaxed text-warm-600 line-clamp-2">
								{related.description}
							</p>
						</Card>
					))}
				</div>
			</section>
		)}
	</article>

	<!-- Spacer before footer -->
	<div class="h-16" />
</BaseLayout>

<script is:inline>
(() => {
	const btn = document.querySelector('.copy-url-btn');
	if (!btn) return;
	btn.addEventListener('click', () => {
		const url = btn.getAttribute('data-copy-url');
		if (!url || !navigator.clipboard) return;
		navigator.clipboard.writeText(decodeURIComponent(url));
	});
})();
</script>
