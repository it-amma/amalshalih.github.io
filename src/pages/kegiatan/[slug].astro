---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';
import Button from '../../components/ui/Button.astro';
import { KATEGORI_LABELS } from '../../lib/constants';
import { getKegiatanList, getKegiatanItem } from '../../lib/sanity/client';
import { renderPortableText } from '../../lib/sanity/render';

export async function getStaticPaths() {
  const slugs = new Set<string>();

  try {
    const sanityItems = await getKegiatanList();
    for (const item of sanityItems) slugs.add(item.slug);
  } catch {
    // Sanity unavailable
  }

  const localItems = await getCollection('kegiatan');
  for (const item of localItems) slugs.add(item.id);

  return Array.from(slugs).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

type PageData = {
  title: string;
  description: string;
  date: Date;
  kategori: string;
  fromSanity: boolean;
  bodyHtml: string;
};

let pageData: PageData | null = null;

try {
  const sanityItem = await getKegiatanItem(slug);
  if (sanityItem) {
    pageData = {
      title: sanityItem.title,
      description: sanityItem.excerpt ?? '',
      date: new Date(sanityItem.date),
      kategori: sanityItem.category,
      fromSanity: true,
      bodyHtml: renderPortableText(sanityItem.body),
    };
  }
} catch {
  // Sanity unavailable
}

let Content = null;

if (!pageData) {
  const localItems = await getCollection('kegiatan');
  const localItem = localItems.find((item) => item.id === slug);
  if (localItem) {
    const rendered = await render(localItem);
    Content = rendered.Content;
    pageData = {
      title: localItem.data.title,
      description: localItem.data.description,
      date: localItem.data.date,
      kategori: localItem.data.kategori,
      fromSanity: false,
      bodyHtml: '',
    };
  }
}

if (!pageData) {
  return Astro.redirect('/kegiatan');
}

const { title, description, date, kategori, fromSanity, bodyHtml } = pageData;
---

<BaseLayout
	title={title}
	description={description}
>
	<article class="mx-auto max-w-3xl px-4 py-16">
		<!-- Back link -->
		<a
			href="/kegiatan"
			class="mb-8 inline-flex items-center gap-1 text-sm font-medium text-warm-700 hover:text-primary-700 transition-colors"
		>
			<Icon name="arrow-left" size={4} />
			Semua Kegiatan
		</a>

		<!-- Header -->
		<header class="mb-10">
			<div class="mb-4 flex flex-wrap items-center gap-3">
				<span class="inline-block rounded-full bg-primary-50 px-3 py-1 text-sm font-medium text-primary-600">
					{KATEGORI_LABELS[kategori] || kategori}
				</span>
				<time datetime={date.toISOString()} class="text-sm text-warm-500">
					{date.toLocaleDateString('id-ID', {
						year: 'numeric',
						month: 'long',
						day: 'numeric',
					})}
				</time>
			</div>
			<h1 class="text-3xl font-extrabold leading-tight text-warm-900 sm:text-4xl">
				{title}
			</h1>
			<p class="mt-3 text-lg text-warm-700">
				{description}
			</p>
		</header>

		<!-- Content -->
		<div class="prose prose-warm max-w-none
			prose-headings:text-warm-900 prose-headings:font-bold
			prose-p:text-warm-700 prose-p:leading-relaxed
			prose-a:text-primary-600 prose-a:no-underline hover:prose-a:underline
			prose-strong:text-warm-900
			prose-blockquote:border-primary-400 prose-blockquote:bg-warm-50 prose-blockquote:px-6 prose-blockquote:py-4 prose-blockquote:rounded-r-lg prose-blockquote:not-italic
			prose-li:text-warm-700
		">
			{fromSanity ? <div set:html={bodyHtml} /> : Content && <Content />}
		</div>

		<!-- CTA Donasi -->
		<div class="mt-12 rounded-2xl bg-primary-50 p-8 text-center ring-1 ring-primary-100">
			<h2 class="text-xl font-bold text-primary-800">Dukung Program Kami</h2>
			<p class="mt-2 text-sm text-primary-700">
				Setiap donasi Anda membantu kami menjangkau lebih banyak penerima manfaat.
			</p>
			<Button variant="primary" href="/donasi" class="mt-4">
				Donasi Sekarang
				<Icon name="arrow-right" size={5} />
			</Button>
		</div>
	</article>
</BaseLayout>
