---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import PageHeader from '../components/sections/PageHeader.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import Icon from '../components/ui/Icon.astro';
import { getBankDonasi, getSiteSettings } from '../lib/sanity/client';
import { DONATION, CONTACT } from '../data/site';

// Hybrid: try Sanity first, fall back to local data
let banks = DONATION.banks.map(b => ({ ...b }));
let qrisImage = DONATION.qrisImage;
let linktreeUrl = DONATION.linktree.url;
let contactPhone = CONTACT.phone;
let contactWhatsapp = CONTACT.whatsapp;

try {
  const [sanityBanks, sanitySettings] = await Promise.all([
    getBankDonasi(),
    getSiteSettings(),
  ]);

  if (sanityBanks && sanityBanks.length > 0) {
    const localFullNames = new Map(DONATION.banks.map(b => [b.name, b.fullName]));
    banks = sanityBanks.map(b => ({
      name: b.bankName,
      fullName: localFullNames.get(b.bankName) ?? b.bankName,
      accountNumber: b.accountNumber,
      accountName: b.accountName,
    }));
  }

  if (sanitySettings) {
    if (sanitySettings.qrisImageUrl) qrisImage = sanitySettings.qrisImageUrl;
    if (sanitySettings.linktree) linktreeUrl = sanitySettings.linktree;
    if (sanitySettings.phone) contactPhone = sanitySettings.phone;
  }
} catch {
  // Sanity unavailable — use local data silently
}

const firstBank = banks[0];
---

<BaseLayout
	title="Donasi"
	description="Salurkan donasi Anda untuk Yayasan Amal Shalih Insan Bantul melalui transfer bank (BSI, BRI, Mandiri, BNI, BCA), QRIS, atau Linktree. Setiap rupiah menjadi amal jariyah."
	currentPage="/donasi"
>
	<PageHeader
		label="Donasi"
		title="Salurkan Donasi Anda"
		description="Setiap rupiah yang Anda donasikan akan menjadi amal jariyah yang pahalanya terus mengalir."
		gradient="r"
	/>

	<!-- Donation Channels -->
	<Container class="py-8 sm:py-16">
		<div class="grid gap-5 sm:gap-8 grid-cols-1 lg:grid-cols-3 items-start">
			<!-- Bank Transfer -->
			<Card variant="hover" class="sm:p-6">
				<div class="mb-3 icon-box">
					<Icon name="credit-card" size={7} aria-hidden="true" />
				</div>
				<h2 class="text-lg sm:text-xl font-bold text-warm-900">Transfer Bank</h2>
				<p class="mt-2 text-sm text-warm-700">Salurkan donasi melalui rekening resmi Yayasan ASIB di bawah ini.</p>

				<!-- Pilih Bank via Dropdown -->
				<div class="mt-5" data-bank-selector>
					<label for="bank-select" class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-warm-500">
						Pilih Bank
					</label>
					<select
						id="bank-select"
						class="block w-full rounded-xl border border-primary-200 bg-white px-4 py-2.5 text-sm font-medium text-warm-900 shadow-sm transition-colors focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
					>
						{banks.map((bank, i) => (
							<option value={i} selected={i === 0}>{bank.name}</option>
						))}
					</select>

					<!-- Detail Rekening -->
					<div class="mt-4">
						{banks.map((bank, i) => (
							<div class={`bank-detail ${i === 0 ? '' : 'hidden'}`} data-index={i}>
								<div class="rounded-xl sm:rounded-2xl border border-primary-100 bg-white p-4 sm:p-5">
									<div class="flex items-center justify-between mb-3 sm:mb-4">
										<div class="flex items-center gap-2">
											<div class="rounded-lg bg-primary-50 p-2 text-primary-700">
												<Icon name="credit-card" size={5} aria-hidden="true" />
											</div>
											<span class="text-sm font-semibold text-warm-900">{bank.fullName}</span>
										</div>
										<span class="text-[10px] font-semibold uppercase tracking-wider text-warm-800">Rekening Resmi</span>
									</div>

									<div class="flex items-center justify-between rounded-lg sm:rounded-xl bg-warm-50 p-3 sm:p-4">
										<div>
											<p class="text-[11px] font-semibold uppercase tracking-wide text-warm-500">Nomor Rekening</p>
											<p class="mt-0.5 text-lg sm:text-xl font-extrabold tracking-wider text-primary-700 font-mono">{bank.accountNumber}</p>
										</div>
										<button
											type="button"
											class="copy-btn inline-flex h-9 w-9 items-center justify-center rounded-lg bg-white text-primary-700 shadow-sm transition-colors duration-200, transform duration-200 hover:bg-primary-50 active:scale-90"
											data-copy={bank.accountNumber}
											aria-label="Salin nomor rekening"
										>
											<Icon name="copy" size={4.5} class="copy-icon" aria-hidden="true" />
											<Icon name="check" size={4.5} class="check-icon hidden" aria-hidden="true" />
										</button>
									</div>

									<p class="mt-2 text-center text-sm text-warm-600">
										a.n. <span class="font-semibold text-warm-900">{bank.accountName}</span>
									</p>
								</div>
							</div>
						))}
					</div>
				</div>

				<div class="mt-3 rounded-lg sm:rounded-xl bg-gold-50 px-4 py-3 text-sm text-gold-800">
					<strong>Konfirmasi donasi:</strong> Setelah transfer, kirim bukti ke WhatsApp <strong>{contactPhone}</strong>.
				</div>
			</Card>

			<!-- QRIS -->
			<Card variant="hover" class="sm:p-6">
				<div class="mb-3 icon-box">
					<Icon name="qrcode" size={7} aria-hidden="true" />
				</div>
				<h2 class="text-lg sm:text-xl font-bold text-warm-900">QRIS</h2>
				<p class="mt-2 text-sm text-warm-700">
					Scan kode QRIS berikut menggunakan aplikasi mobile banking atau e-wallet Anda.
				</p>
				<div class="mt-4 flex justify-center">
					<img
						src={qrisImage}
						alt="QRIS Yayasan Amal Shalih Insan Bantul"
						class="h-52 sm:h-64 w-auto max-w-full rounded-lg sm:rounded-xl border border-primary-100"
						width="778"
						height="800"
						loading="lazy"
					/>
				</div>
				<div class="mt-3 rounded-lg bg-primary-50 p-3 sm:p-4 text-sm text-primary-800">
					<strong>Cara:</strong> Buka aplikasi berlogo QRIS → Scan kode → Cek nominal → Donasi/Bayar
				</div>
			</Card>

			<!-- Kitabisa & Online -->
			<Card variant="hover" class="sm:p-6">
				<div class="mb-3 icon-box">
					<Icon name="globe" size={7} aria-hidden="true" />
				</div>
				<h2 class="text-lg sm:text-xl font-bold text-warm-900">Donasi Online</h2>
				<p class="mt-2 text-sm text-warm-700">
					Kunjungi platform donasi online kami melalui link berikut.
				</p>
				<div class="mt-4 space-y-3">
					<a
						href={linktreeUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="flex items-center gap-3 rounded-lg sm:rounded-xl border border-primary-200 bg-white p-3 sm:p-4 transition-colors duration-200, border-color duration-200, shadow duration-200 hover:border-primary-400 hover:bg-primary-50 hover:shadow-sm"
					>
						<div class="rounded-lg bg-primary-100 p-2 text-primary-700 shrink-0">
							<Icon name="external-link" size={6} aria-hidden="true" />
						</div>
						<div class="min-w-0">
							<p class="truncate font-semibold text-warm-900">{linktreeUrl.replace('https://', '')}</p>
							<p class="text-xs text-warm-900">Semua program donasi dalam satu tautan</p>
						</div>
						<Icon name="external-link" size={5} class="shrink-0 text-warm-600" aria-hidden="true" />
					</a>
				</div>
				<div class="mt-4 rounded-lg sm:rounded-xl bg-warm-50 p-4 sm:p-5">
					<h3 class="font-semibold text-warm-800">Butuh bantuan?</h3>
					<p class="mt-1 text-sm text-warm-700">
						Hubungi admin kami melalui WhatsApp:
					</p>
					<Button variant="whatsapp" href={contactWhatsapp} class="mt-2" target="_blank" rel="noopener noreferrer">
						<Icon name="whatsapp" size={4} aria-hidden="true" />
						Chat WhatsApp
					</Button>
				</div>
			</Card>
		</div>
	</Container>

	<!-- Ayat Motivasi -->
	<section class="bg-gradient-to-r from-gold-50 to-primary-50">
		<Container as="div" class="py-8 sm:py-16">
			<div class="rounded-xl sm:rounded-2xl bg-white p-5 sm:p-8 shadow-md ring-1 ring-primary-100/50 text-center lg:p-12">
				<Icon name="book" size={10} class="mx-auto text-gold-500 sm:size-12" aria-hidden="true" />
				<blockquote class="mt-4 sm:mt-6">
					<p class="text-lg sm:text-xl font-semibold leading-relaxed text-warm-800 sm:text-2xl">
						&ldquo;Perumpamaan orang yang menginfakkan hartanya di jalan Allah
						seperti sebutir biji yang menumbuhkan tujuh bulir, pada tiap-tiap bulir
						terdapat seratus biji.&rdquo;
					</p>
				</blockquote>
				<p class="mt-3 text-sm font-medium text-primary-700">— QS. Al-Baqarah: 261</p>
			</div>
		</Container>
	</section>
</BaseLayout>

<!-- Client-side: Dropdown bank switching + Clipboard -->
<script is:inline>
(() => {
	const root = document.querySelector('[data-bank-selector]');
	if (!root) return;

	const select = root.querySelector('#bank-select');
	const details = root.querySelectorAll('.bank-detail');

	if (!select || details.length === 0) return;

	// Show initial
	select.dispatchEvent(new Event('change'));

	select.addEventListener('change', () => {
		const idx = select.value;
		details.forEach((el) => {
			el.classList.toggle('hidden', el.getAttribute('data-index') !== idx);
		});
	});

	// Clipboard
	root.querySelectorAll('.copy-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			const num = btn.getAttribute('data-copy');
			const copyIcon = btn.querySelector('.copy-icon');
			const checkIcon = btn.querySelector('.check-icon');
			if (!navigator.clipboard || !num) return;
			navigator.clipboard.writeText(num).then(() => {
				copyIcon?.classList.add('hidden');
				checkIcon?.classList.remove('hidden');
				setTimeout(() => {
					copyIcon?.classList.remove('hidden');
					checkIcon?.classList.add('hidden');
				}, 2000);
			});
		});
	});
})();
</script>