---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import PageHeader from '../components/sections/PageHeader.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import Icon from '../components/ui/Icon.astro';
import { getBankDonasi, getSiteSettings } from '../lib/sanity/client';
import { DONATION, CONTACT } from '../data/site';

// Hybrid: try Sanity first, fall back to local data
let banks = DONATION.banks.map(b => ({ ...b }));
let qrisImage = DONATION.qrisImage;
let linktreeUrl = DONATION.linktree.url;
let contactPhone = CONTACT.phone;
let contactWhatsapp = CONTACT.whatsapp;

try {
  const [sanityBanks, sanitySettings] = await Promise.all([
    getBankDonasi(),
    getSiteSettings(),
  ]);

  if (sanityBanks && sanityBanks.length > 0) {
    const localFullNames = new Map(DONATION.banks.map(b => [b.name, b.fullName]));
    banks = sanityBanks.map(b => ({
      name: b.bankName,
      fullName: localFullNames.get(b.bankName) ?? b.bankName,
      accountNumber: b.accountNumber,
      accountName: b.accountName,
    }));
  }

  if (sanitySettings) {
    if (sanitySettings.qrisImageUrl) qrisImage = sanitySettings.qrisImageUrl;
    if (sanitySettings.linktree) linktreeUrl = sanitySettings.linktree;
    if (sanitySettings.phone) contactPhone = sanitySettings.phone;
  }
} catch {
  // Sanity unavailable — use local data silently
}

const firstBank = banks[0];
---

<BaseLayout
	title="Donasi"
	description="Salurkan donasi Anda untuk Yayasan Amal Shalih Insan Bantul melalui transfer bank (BSI, BRI, Mandiri, BNI, BCA), QRIS, atau Linktree. Setiap rupiah menjadi amal jariyah."
	currentPage="/donasi"
>
	<PageHeader
		label="Donasi"
		title="Salurkan Donasi Anda"
		description="Setiap rupiah yang Anda donasikan akan menjadi amal jariyah yang pahalanya terus mengalir."
		gradient="r"
	/>

	<!-- Donation Channels -->
	<Container class="py-8 sm:py-16">
		<div class="grid gap-5 sm:gap-6 md:grid-cols-3">
			<!-- QRIS — Moved to top for mobile visibility, order restored on sm+ -->
			<Card variant="hover" class="relative overflow-hidden order-first sm:order-none sm:p-6 h-full">
				<!-- Background watermark — mobile only, position randomized per reload -->
				<div class="absolute sm:hidden pointer-events-none text-primary-500/[0.06]" data-donation-watermark>
					<Icon name="qrcode" size={24} aria-hidden="true" />
				</div>
				<div class="mb-3 icon-box hidden sm:inline-flex">
					<Icon name="qrcode" size={7} aria-hidden="true" />
				</div>
				<h2 class="text-lg sm:text-xl font-bold text-warm-900">QRIS</h2>
				<p class="mt-2 text-sm text-warm-700">
					Scan kode QRIS berikut menggunakan aplikasi mobile banking atau e-wallet Anda.
				</p>
				<div class="mt-4 flex justify-center">
					<img
						src={qrisImage}
						alt="QRIS Yayasan Amal Shalih Insan Bantul"
						class="h-52 sm:h-64 w-auto max-w-xs sm:max-w-sm rounded-lg sm:rounded-xl shadow-sm"
						width="778"
						height="800"
						loading="lazy"
						decoding="async"
					/>
				</div>
				<div class="mt-3 rounded-lg bg-primary-50 p-3 sm:p-4 text-sm text-primary-800">
					<strong>Cara:</strong> Buka aplikasi berlogo QRIS → Scan kode → Cek nominal → Donasi/Bayar
				</div>
			</Card>

			<!-- Bank Transfer — Primary -->
			<Card variant="hover" class="relative overflow-hidden sm:p-6 h-full">
				<!-- Background watermark — mobile only, position randomized per reload -->
				<div class="absolute sm:hidden pointer-events-none text-primary-500/[0.06]" data-donation-watermark>
					<Icon name="credit-card" size={24} aria-hidden="true" />
				</div>
				<div class="mb-3 icon-box hidden sm:inline-flex">
					<Icon name="credit-card" size={7} aria-hidden="true" />
				</div>
				<h2 class="text-lg sm:text-xl font-bold text-warm-900">Transfer Bank</h2>
				<p class="mt-2 text-sm text-warm-700">Salurkan donasi melalui rekening resmi Yayasan ASIB di bawah ini.</p>

				<!-- Pilih Bank via Dropdown -->
				<div class="mt-5" data-bank-selector>
					<label for="bank-select" class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-warm-500">
						Pilih Bank
					</label>
					<select
						id="bank-select"
						class="block w-full rounded-xl border border-primary-200 bg-white px-4 py-2.5 text-sm font-medium text-warm-900 shadow-sm transition-colors focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
					>
						{banks.map((bank, i) => (
							<option value={i} selected={i === 0}>{bank.name}</option>
						))}
					</select>

					<!-- Detail Rekening -->
					<div class="mt-4">
						{banks.map((bank, i) => (
							<div class={`bank-detail ${i === 0 ? '' : 'hidden'}`} data-index={i}>
								<div class="rounded-xl sm:rounded-2xl bg-white p-4 sm:p-5 shadow-sm">
									<div class="flex items-center justify-between mb-3 sm:mb-4">
										<div class="flex items-center gap-2">
											<div class="rounded-lg bg-primary-50 p-2 text-primary-700">
												<Icon name="credit-card" size={5} aria-hidden="true" />
											</div>
											<span class="text-sm font-semibold text-warm-900">{bank.fullName}</span>
										</div>
										<span class="text-[10px] font-semibold uppercase tracking-wider text-warm-800">Rekening Resmi</span>
									</div>

									<div class="flex items-center justify-between rounded-lg sm:rounded-xl bg-warm-50 p-3 sm:p-4">
										<div>
											<p class="text-[11px] font-semibold uppercase tracking-wide text-warm-500">Nomor Rekening</p>
											<p class="mt-0.5 text-lg sm:text-xl font-extrabold tracking-wider text-primary-700 font-mono">{bank.accountNumber}</p>
										</div>
										<button
											type="button"
											class="copy-btn inline-flex h-9 w-9 items-center justify-center rounded-lg bg-white text-primary-700 shadow-sm transition-colors duration-200 hover:bg-primary-50 active:scale-90"
											data-copy={bank.accountNumber}
											aria-label="Salin nomor rekening"
										>
											<Icon name="copy" size={4.5} class="copy-icon" aria-hidden="true" />
											<Icon name="check" size={4.5} class="check-icon hidden" aria-hidden="true" />
										</button>
									</div>

									<p class="mt-2 text-center text-sm text-warm-600">
										a.n. <span class="font-semibold text-warm-900">{bank.accountName}</span>
									</p>
								</div>
							</div>
						))}
					</div>
				</div>

				<div class="mt-3 rounded-lg sm:rounded-xl bg-gold-50 px-4 py-3 text-sm text-gold-800">
					<strong>Konfirmasi donasi:</strong> Setelah transfer, kirim bukti ke WhatsApp <strong>{contactPhone}</strong>.
				</div>
			</Card>

			<!-- Kitabisa & Online -->
			<Card variant="hover" class="relative overflow-hidden sm:p-6 h-full">
				<!-- Background watermark — mobile only, position randomized per reload -->
				<div class="absolute sm:hidden pointer-events-none text-primary-500/[0.06]" data-donation-watermark>
					<Icon name="globe" size={24} aria-hidden="true" />
				</div>
				<div class="mb-3 icon-box hidden sm:inline-flex">
					<Icon name="globe" size={7} aria-hidden="true" />
				</div>
				<h2 class="text-lg sm:text-xl font-bold text-warm-900">Donasi Online</h2>
				<p class="mt-2 text-sm text-warm-700">
					Kunjungi platform donasi online kami melalui link berikut.
				</p>
				<div class="mt-4 space-y-3">
					<a
						href={linktreeUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="flex items-center gap-3 rounded-lg sm:rounded-xl border border-primary-200 bg-white p-3 sm:p-4 transition-colors duration-200 hover:border-primary-400 hover:bg-primary-50 hover:shadow-sm"
					>
						<div class="rounded-lg bg-primary-100 p-2 text-primary-700 shrink-0">
							<Icon name="external-link" size={6} aria-hidden="true" />
						</div>
						<div class="min-w-0">
							<p class="truncate font-semibold text-warm-900">{linktreeUrl.replace('https://', '')}</p>
							<p class="text-xs text-warm-900">Semua program donasi dalam satu tautan</p>
						</div>
						<Icon name="external-link" size={5} class="shrink-0 text-warm-600" aria-hidden="true" />
					</a>
				</div>
				<div class="mt-4 rounded-lg sm:rounded-xl bg-warm-50 p-4 sm:p-5">
					<h3 class="font-semibold text-warm-800">Butuh bantuan?</h3>
					<p class="mt-1 text-sm text-warm-700">
						Hubungi admin kami melalui WhatsApp:
					</p>
					<div class="mt-2 flex justify-end sm:block">
						<Button variant="primary" href={contactWhatsapp} target="_blank" rel="noopener noreferrer">
							<Icon name="whatsapp" size={4} aria-hidden="true" />
							Chat WhatsApp
						</Button>
					</div>
				</div>
			</Card>
		</div>
	</Container>

	<Fragment slot="after-main">
		<!-- Sacred Geometry & Architecture — honeycomb tessellation + mosque dome silhouettes -->
		<section class="relative overflow-hidden bg-gradient-to-b from-primary-50 via-gold-50/30 to-warm-50">
			<!-- Honeycomb tessellation overlay using hexagon clip-path -->
			<div class="absolute inset-0 opacity-[0.04]" aria-hidden="true">
				<!-- Row 1 -->
				<div class="absolute top-[8%] left-[5%] w-10 h-[11.5px] bg-primary-400" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>
				<div class="absolute top-[8%] left-[13%] w-10 h-[11.5px] bg-gold-400" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>
				<div class="absolute top-[12%] left-[9%] w-10 h-[11.5px] bg-primary-400" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>
				<div class="absolute top-[8%] right-[8%] w-10 h-[11.5px] bg-gold-400" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>
				<div class="absolute top-[12%] right-[12%] w-10 h-[11.5px] bg-primary-400" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>
				<!-- Row 2 -->
				<div class="absolute top-[22%] left-[18%] w-8 h-9 bg-gold-300" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>
				<div class="absolute top-[26%] left-[22%] w-8 h-9 bg-primary-300" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>
				<div class="absolute top-[20%] right-[18%] w-8 h-9 bg-primary-300" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>
				<!-- Row 3 (bottom area) -->
				<div class="absolute bottom-[18%] left-[7%] w-9 h-10 bg-gold-300" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>
				<div class="absolute bottom-[22%] left-[11%] w-9 h-10 bg-primary-300" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>
				<div class="absolute bottom-[15%] right-[6%] w-9 h-10 bg-primary-300" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>
				<div class="absolute bottom-[20%] right-[10%] w-9 h-10 bg-gold-300" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>
			</div>

			<!-- Mosque dome (mustaka) silhouettes — asymmetric, architectural -->
			<div class="absolute bottom-0 right-[5%] w-28 h-20 bg-gradient-to-t from-primary-200/25 to-transparent rounded-t-full" style="border-radius: 50% 50% 0 0 / 100% 100% 0 0;" aria-hidden="true"></div>
			<div class="absolute bottom-0 right-[15%] w-20 h-14 bg-gradient-to-t from-gold-200/20 to-transparent rounded-t-full" style="border-radius: 50% 50% 0 0 / 100% 100% 0 0;" aria-hidden="true"></div>
			<div class="absolute bottom-0 left-[8%] w-16 h-11 bg-gradient-to-t from-primary-200/15 to-transparent rounded-t-full" style="border-radius: 50% 50% 0 0 / 100% 100% 0 0;" aria-hidden="true"></div>

			<!-- Scattered floating star accents -->
			<div class="absolute top-6 right-[22%] text-gold-400/20" aria-hidden="true"><Icon name="star" size={3} /></div>
			<div class="absolute top-10 left-[16%] text-primary-400/15" aria-hidden="true"><Icon name="star" size={2.5} /></div>
			<div class="absolute bottom-24 right-[28%] text-gold-400/15" aria-hidden="true"><Icon name="star" size={2} /></div>
			<div class="absolute top-[35%] left-[4%] text-primary-400/10" aria-hidden="true"><div class="w-2 h-2 rotate-45 bg-current rounded-[1px]"></div></div>
			<div class="absolute bottom-[30%] right-[4%] text-gold-400/12" aria-hidden="true"><div class="w-1.5 h-1.5 rotate-45 bg-current rounded-[1px]"></div></div>

			<Container as="div" class="relative z-10 py-5 sm:py-6 lg:py-8">
				<!-- Glassmorphism card with ethereal feel -->
				<div class="relative mx-auto max-w-3xl rounded-xl sm:rounded-2xl bg-white/50 backdrop-blur-xl border border-white/50 shadow-xl shadow-primary-900/5 p-5 sm:p-8 text-center overflow-hidden">
					<!-- Decorative large quote mark -->
					<div class="absolute -top-2 left-3 sm:left-6 text-[5rem] sm:text-[7rem] leading-none font-serif text-gold-400/10 select-none pointer-events-none" aria-hidden="true">&ldquo;</div>

					<blockquote class="relative">
						<p class="text-base sm:text-lg lg:text-xl font-semibold leading-relaxed text-warm-900 font-display">
							Perumpamaan orang yang menginfakkan hartanya di jalan Allah
							seperti sebutir biji yang menumbuhkan tujuh bulir, pada tiap-tiap bulir
							terdapat seratus biji.
						</p>
					</blockquote>

					<div class="mx-auto mt-4 h-0.5 w-10 sm:w-14 rounded-full bg-gradient-to-r from-gold-300 to-gold-500"></div>

					<p class="mt-3 text-xs sm:text-sm font-semibold tracking-wide text-primary-700 uppercase">
						— QS. Al-Baqarah: 261
					</p>
				</div>
			</Container>
		</section>
	</Fragment>
</BaseLayout>

<!-- Client-side: Dropdown bank switching + Clipboard -->
<script is:inline>
(() => {
	const root = document.querySelector('[data-bank-selector]');
	if (!root) return;

	const select = root.querySelector('#bank-select');
	const details = root.querySelectorAll('.bank-detail');

	if (!select || details.length === 0) return;

	// Show initial
	select.dispatchEvent(new Event('change'));

	select.addEventListener('change', () => {
		const idx = select.value;
		details.forEach((el) => {
			el.classList.toggle('hidden', el.getAttribute('data-index') !== idx);
		});
	});

	// Clipboard
	root.querySelectorAll('.copy-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			const num = btn.getAttribute('data-copy');
			const copyIcon = btn.querySelector('.copy-icon');
			const checkIcon = btn.querySelector('.check-icon');
			if (!navigator.clipboard || !num) return;
			navigator.clipboard.writeText(num).then(() => {
				copyIcon?.classList.add('hidden');
				checkIcon?.classList.remove('hidden');
				setTimeout(() => {
					copyIcon?.classList.remove('hidden');
					checkIcon?.classList.add('hidden');
				}, 2000);
			});
		});
	});
})();

	// Randomize donation watermark position on each reload for visual variety
	(() => {
		const positions = [
			{ top: '-24px', right: '-24px', transform: 'rotate(12deg)' },
			{ bottom: '-24px', right: '-24px', transform: 'rotate(-12deg)' },
			{ top: '-24px', left: '-24px', transform: 'rotate(-12deg)' },
			{ bottom: '-24px', left: '-24px', transform: 'rotate(12deg)' },
			{ top: '50%', right: '-24px', transform: 'translateY(-50%) rotate(6deg)' },
			{ top: '50%', left: '-24px', transform: 'translateY(-50%) rotate(-6deg)' },
		];
			document.querySelectorAll('[data-donation-watermark]').forEach((el) => {
				const pos = positions[Math.floor(Math.random() * positions.length)];
				Object.assign((el).style, pos);
			});
	})();
</script>