---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/sections/PageHeader.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import Icon from '../components/ui/Icon.astro';
import { DONATION, CONTACT } from '../data/site';
---

<BaseLayout
	title="Donasi"
	description="Salurkan donasi Anda untuk Yayasan Amal Shalih Insan Bantul melalui transfer bank BSI, QRIS, atau Kitabisa. Setiap rupiah menjadi amal jariyah."
	currentPage="/donasi"
>
	<PageHeader
		label="Donasi"
		title="Salurkan Donasi Anda"
		description="Setiap rupiah yang Anda donasikan akan menjadi amal jariyah yang pahalanya terus mengalir."
	/>

	<!-- Donation Channels -->
	<section class="mx-auto max-w-6xl px-4 py-16">
		<div class="grid gap-8 lg:grid-cols-3">
			<!-- Bank Transfer -->
			<Card variant="hover" class="p-8">
				<div class="mb-4 icon-box">
					<Icon name="credit-card" size={7} />
				</div>
				<h2 class="text-xl font-bold text-warm-900">Transfer Bank</h2>
				<div class="mt-6 rounded-xl bg-warm-50 p-5">
					<div class="mb-4 flex items-center gap-3">
						<div class="rounded-lg bg-primary-600 px-3 py-2 text-sm font-bold text-white">{DONATION.bank.name}</div>
						<span class="text-sm font-medium text-warm-700">{DONATION.bank.fullName}</span>
					</div>
					<p class="text-2xl font-bold tracking-wider text-warm-900">{DONATION.bank.accountNumber}</p>
					<p class="mt-1 text-sm text-warm-700">a.n. <strong>{DONATION.bank.accountName}</strong></p>
				</div>
				<div class="mt-4 rounded-lg bg-gold-50 p-4 text-sm text-gold-800">
					<strong>Konfirmasi donasi:</strong> Setelah transfer, silakan kirim bukti
					ke WhatsApp <strong>{CONTACT.phone}</strong>.
				</div>
			</Card>

			<!-- QRIS -->
			<Card variant="hover" class="p-8">
				<div class="mb-4 icon-box">
					<Icon name="qrcode" size={7} />
				</div>
				<h2 class="text-xl font-bold text-warm-900">QRIS</h2>
				<p class="mt-2 text-sm text-warm-700">
					Scan kode QRIS berikut menggunakan aplikasi mobile banking atau e-wallet Anda.
				</p>
				<div class="mt-6 flex justify-center">
					<img
						src={DONATION.qrisImage}
						alt="QRIS Yayasan Amal Shalih Insan Bantul"
						class="h-64 w-auto max-w-full rounded-xl border border-primary-100"
						width="778"
						height="800"
						loading="lazy"
					/>
				</div>
				<div class="mt-4 rounded-lg bg-primary-50 p-4 text-sm text-primary-800">
					<strong>Cara:</strong> Buka aplikasi berlogo QRIS → Scan kode → Cek nominal → Donasi/Bayar
				</div>
			</Card>

			<!-- Kitabisa & Online -->
			<Card variant="hover" class="p-8">
				<div class="mb-4 icon-box">
					<Icon name="globe" size={7} />
				</div>
				<h2 class="text-xl font-bold text-warm-900">Donasi Online</h2>
				<p class="mt-2 text-sm text-warm-700">
					Kunjungi platform donasi online kami melalui link berikut.
				</p>
				<div class="mt-6 space-y-4">
					<a
						href={DONATION.linktree.url}
						target="_blank"
						rel="noopener noreferrer"
						class="flex items-center gap-3 rounded-xl border border-primary-200 bg-white p-4 transition-colors hover:border-primary-400 hover:bg-primary-50"
					>
						<div class="rounded-lg bg-primary-100 p-2 text-primary-600">
							<Icon name="external-link" size={6} />
						</div>
						<div>
							<p class="font-semibold text-warm-900">{DONATION.linktree.url.replace('https://', '')}</p>
							<p class="text-xs text-warm-700">Semua program donasi dalam satu tautan</p>
						</div>
						<Icon name="external-link" size={5} class="ml-auto text-warm-500" />
					</a>
				</div>
				<div class="mt-6 rounded-xl bg-warm-50 p-5">
					<h3 class="font-semibold text-warm-800">Butuh bantuan?</h3>
					<p class="mt-2 text-sm text-warm-700">
						Hubungi admin kami melalui WhatsApp:
					</p>
					<Button variant="whatsapp" href={CONTACT.whatsapp} class="mt-3" target="_blank">
						<Icon name="whatsapp" size={4} />
						Chat WhatsApp
					</Button>
				</div>
			</Card>
		</div>
	</section>

	<!-- Ayat Motivasi -->
	<section class="bg-gradient-to-r from-gold-50 to-primary-50">
		<div class="mx-auto max-w-6xl px-4 py-16">
			<div class="rounded-2xl bg-white p-8 shadow-md ring-1 ring-primary-100/50 text-center sm:p-12">
				<Icon name="book" size={12} class="mx-auto text-gold-500" />
				<blockquote class="mt-6">
					<p class="text-xl font-semibold leading-relaxed text-warm-800 sm:text-2xl">
						&ldquo;Perumpamaan orang yang menginfakkan hartanya di jalan Allah
						seperti sebutir biji yang menumbuhkan tujuh bulir, pada tiap-tiap bulir
						terdapat seratus biji.&rdquo;
					</p>
				</blockquote>
				<p class="mt-4 text-sm font-medium text-primary-600">— QS. Al-Baqarah: 261</p>
			</div>
		</div>
	</section>
</BaseLayout>
