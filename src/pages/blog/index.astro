---
import { getCollection } from 'astro:content'
import PageHeader from '../../components/sections/PageHeader.astro'
import Card from '../../components/ui/Card.astro'
import Container from '../../components/ui/Container.astro'
import Icon from '../../components/ui/Icon.astro'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getBlogPostList } from '../../lib/sanity/client'

interface BlogPost {
	id: string
	data: {
		title: string
		description: string
		date: Date
		image?: string
		category?: string
	}
}

let posts: BlogPost[] = []

// Try Sanity first
try {
	const sanityPosts = await getBlogPostList()
	if (sanityPosts && sanityPosts.length > 0) {
		posts = sanityPosts.map((post) => ({
			id: post.slug,
			data: {
				title: post.title,
				description: post.excerpt ?? '',
				date: new Date(post.date),
				image: post.imageUrl,
				category: post.category,
			},
		}))
	}
} catch (error) {
	console.error('[Blog Index] Sanity blog fetch failed:', error)
}

// Fall back to markdown collection
if (posts.length === 0) {
	const markdownPosts = await getCollection('blog')
	posts = markdownPosts.map((post) => ({
		id: post.id,
		data: {
			title: post.data.title,
			description: post.data.description,
			date: post.data.date,
			image: post.data.image,
			category: post.data.category,
		},
	}))
}

const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
---

<BaseLayout
	title="Blog & Edukasi"
	description="Artikel edukasi dan informasi seputar keislaman, sosial kemanusiaan, dan update terbaru Yayasan Amal Shalih Insan Bantul untuk menunjang wawasan umat."
	currentPage="/blog"
>
	<PageHeader
		label="Wawasan & Edukasi"
		title="Blog Yayasan ASIB"
		description="Kumpulan artikel mendalam mengenai pendidikan Islam, manajemen zakat, wakaf, dan berbagai tips sosial kemanusiaan."
	/>

	<Container as="section" class="py-12 sm:py-20">
		<div class="grid gap-8 sm:gap-10 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
			{sortedPosts.map(post => (
				<Card
					variant="overflow"
					href={`/blog/${post.id}`}
					class="group flex flex-col h-full bg-white border border-warm-100 hover:border-primary-200 hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
				>
					{post.data.image && (
						<div class="relative aspect-video w-full overflow-hidden">
							<img
								src={post.data.image}
								alt={post.data.title}
								class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
								loading="lazy"
							/>
							<div class="absolute top-4 left-4">
								<span class="rounded-full bg-white/90 backdrop-blur-sm px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-primary-800 shadow-sm ring-1 ring-inset ring-primary-600/20">
									{post.data.category || 'Umum'}
								</span>
							</div>
						</div>
					)}
					<div class="p-4 sm:p-6 flex flex-col flex-1">
						<div class="mb-3 flex items-center gap-2 text-xs text-warm-500 font-medium">
							<Icon name="calendar" size={3.5} class="shrink-0" />
							{post.data.date.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}
						</div>
						<h3 class="mb-2 text-xl font-bold text-warm-900 line-clamp-2 group-hover:text-primary-700 transition-colors leading-snug">
							{post.data.title}
						</h3>
						<p class="mb-4 text-sm text-warm-600 line-clamp-3 leading-relaxed opacity-90">
							{post.data.description}
						</p>
						<div class="mt-auto flex items-center gap-2 text-sm font-bold text-primary-600 group-hover:text-primary-700 transition-colors">
							Baca Selengkapnya
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
							</svg>
						</div>
					</div>
				</Card>
			))}
		</div>
	</Container>
</BaseLayout>
