---
import { getCollection, render } from 'astro:content'
import Container from '../../components/ui/Container.astro'
import Icon from '../../components/ui/Icon.astro'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getBlogPost } from '../../lib/sanity/client'
import { renderPortableText } from '../../lib/sanity/render'

// SSR mode for Cloudflare Workers
export const prerender = false

const { slug } = Astro.params
if (!slug) {
	return Astro.redirect('/blog')
}

// Try Sanity first
let sanityPost = null
let postFromSanity = false
try {
	sanityPost = await getBlogPost(slug)
	if (sanityPost) {
		postFromSanity = true
	}
} catch (error) {
	console.error('[Blog Detail] Sanity fetch failed:', error)
}

let post: {
	id: string
	data: {
		title: string
		description: string
		date: Date
		image?: string
		category?: string
		author?: string
	}
	body?: unknown
} | null = null

let Content: any = null

if (sanityPost) {
	post = {
		id: sanityPost.slug,
		data: {
			title: sanityPost.title,
			description: sanityPost.excerpt ?? '',
			date: new Date(sanityPost.date),
			image: sanityPost.imageUrl,
			category: sanityPost.category,
			author: sanityPost.author,
		},
		body: sanityPost.body,
	}
}

// Fall back to markdown collection
if (!post) {
	const blogPosts = await getCollection('blog')
	const markdownPost = blogPosts.find((p) => p.id === slug)
	if (markdownPost) {
		post = {
			id: markdownPost.id,
			data: {
				title: markdownPost.data.title,
				description: markdownPost.data.description,
				date: markdownPost.data.date,
				image: markdownPost.data.image,
				category: markdownPost.data.category,
				author: markdownPost.data.author,
			},
		}
		const { Content: MarkdownContent } = await render(markdownPost)
		Content = MarkdownContent
	}
}

if (!post) {
	return Astro.redirect('/blog')
}

const formattedDate = post.data.date.toLocaleDateString('id-ID', {
	weekday: 'long',
	year: 'numeric',
	month: 'long',
	day: 'numeric',
})

// Estimate reading time (avg 200 words per minute)
const words = post.body ? String(post.body).split(/\s+/).length : 0
const readingTime = Math.ceil(words / 200) || 3

// Fetch related posts (from markdown for now)
const allPosts = await getCollection('blog')
const relatedPosts = allPosts
	.filter((p) => p.id !== post.id && p.data.category === post.data.category)
	.slice(0, 3)
---

<BaseLayout
	title={post.data.title}
	description={post.data.description}
	image={post.data.image}
	pageType="article"
	publishedTime={post.data.date.toISOString()}
	modifiedTime={post.data.date.toISOString()}
	currentPage={`/blog/${post.id}`}
>
	<!-- Full-Width Hero Section -->
	<div class="relative w-full overflow-hidden bg-warm-50 isolate">
		<!-- Full-Bleed Ambient Background Glow -->
		{post.data.image && (
			<div class="absolute inset-0 z-0 overflow-hidden blur-sm opacity-90 transition-opacity duration-1000" aria-hidden="true">
				<img
					src={post.data.image}
					alt=""
					class="h-full w-full object-cover scale-110"
				/>
			</div>
		)}

		<!-- Readability Gradient Scrim (Strengthened for sharpness) -->
		<div class="absolute inset-0 z-0 bg-gradient-to-r from-warm-50 via-warm-50/60 to-transparent pointer-events-none" aria-hidden="true"></div>

		<!-- Bottom fade to transparent for seamless transition with content card -->
		<div class="absolute bottom-0 left-0 right-0 h-32 z-0 bg-gradient-to-t from-warm-50 via-warm-50/80 to-transparent pointer-events-none" aria-hidden="true"></div>

		<Container as="div" class="relative z-10 pb-16 sm:pb-20 md:pb-24">
			<div class="mx-auto max-w-3xl">
				<!-- Breadcrumbs -->
				<nav class="py-4 mb-6 flex items-center gap-2 text-xs font-medium text-warm-500">
					<a href="/" class="hover:text-primary-600 transition-colors">Beranda</a>
					<Icon name="chevron-right" size={3} class="shrink-0 translate-y-[1px]" />
					<a href="/blog" class="hover:text-primary-600 transition-colors">Blog</a>
					<Icon name="chevron-right" size={3} class="shrink-0 translate-y-[1px]" />
					<span class="text-warm-900 truncate">{post.data.title}</span>
				</nav>

				<!-- Asymmetric Header Layout -->
				<div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
					<!-- Left: Title & Metadata -->
					<div class="md:col-span-7 text-left">
						<div class="hidden md:flex items-center gap-1.5 text-[10px] sm:text-xs font-bold uppercase tracking-widest text-warm-600 mb-3">
							<Icon name="calendar" size={3} class="shrink-0" />
							{formattedDate}
						</div>
						<h1 class="mb-4 text-3xl font-extrabold tracking-tight text-warm-900 sm:text-4xl lg:text-5xl leading-tight">
							{post.data.title}
						</h1>
						<div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-xs sm:text-sm text-warm-700 font-medium">
							<span class="text-warm-900 font-bold">{post.data.author}</span>
							<span class="hidden sm:inline text-warm-400">•</span>
							<span class="rounded-full bg-primary-100/80 px-2 py-0.5 text-[10px] sm:text-xs font-semibold text-primary-700 ring-1 ring-inset ring-primary-600/20">
								{post.data.category || 'Edukasi'}
							</span>
							<span class="hidden sm:inline md:hidden text-warm-400">•</span>
							<div class="flex items-center gap-1.5 md:hidden">
								<Icon name="calendar" size={3.5} class="shrink-0" />
								{formattedDate}
							</div>
							<span class="hidden sm:inline text-warm-400">•</span>
							<div class="flex items-center gap-1.5">
								<Icon name="clock" size={3.5} class="shrink-0" />
								{readingTime} mnt baca
							</div>
						</div>
					</div>

					<!-- Right: Featured Image (Larger & Offloaded) -->
					<div class="md:col-span-5 flex justify-center md:justify-end">
						{post.data.image && (
							<div class="relative group md:-mr-16 md:translate-x-8">
								<!-- Decorative shadow/glow -->
								<div class="absolute -inset-2 bg-gradient-to-r from-primary-600 to-gold-500 rounded-3xl blur opacity-20 group-hover:opacity-40 transition-opacity"></div>

								<!-- Image Container (Clean, no border, smooth lift animation) -->
								<div class="relative overflow-hidden rounded-2xl shadow-2xl transition-all duration-700 hover:-translate-y-2 hover:shadow-3xl rotate-2">
									<img
										src={post.data.image}
										alt={post.data.title}
										class="w-full max-w-sm h-auto object-cover aspect-[4/3]"
										loading="eager"
										decoding="async"
									/>
								</div>
							</div>
						)}
					</div>
				</div>
			</div>
		</section>
	</div>

	<!-- Overlapping Article Content Card -->
	<section class="mx-auto max-w-6xl sm:px-6 lg:px-8 relative z-20 -mt-12 sm:-mt-16 md:-mt-20">
		<div class="mx-auto max-w-3xl bg-gradient-to-b from-white/20 via-white/80 to-white/90 rounded-t-3xl shadow-2xl backdrop-blur-sm px-4 py-5 sm:p-6 lg:p-8">
			<!-- Article Body with Prose Typography -->
			<div class="prose prose-slate max-w-none
				prose-headings:text-warm-900 prose-headings:tracking-tight
				prose-p:text-warm-700 prose-p:leading-relaxed
				prose-a:text-primary-600 hover:prose-a:text-primary-700 prose-a:font-medium
				prose-strong:text-warm-900 prose-strong:font-bold
				prose-blockquote:border-l-primary-500 prose-blockquote:bg-primary-50 prose-blockquote:py-1 prose-blockquote:px-4 prose-blockquote:rounded-r-lg
				prose-img:rounded-2xl prose-img:shadow-md
				sm:prose-lg">
				{postFromSanity && post.body ? (
					<div set:html={renderPortableText(post.body)} />
				) : (
					<Content />
				)}
			</div>

			<!-- Footer / Engagement Section -->
			<div class="mt-20 space-y-12">
				<!-- Share & CTA -->
				<div class="rounded-3xl bg-gradient-to-br from-primary-800 to-primary-950 p-8 sm:p-12 text-center text-white shadow-xl">
					<h3 class="mb-4 text-2xl font-bold text-white">Suka dengan artikel ini?</h3>
					<p class="mb-8 text-primary-100 opacity-90 max-w-xl mx-auto">
						Bagikan informasi bermanfaat ini kepada keluarga dan kerabat untuk menebar kemaslahatan bersama.
					</p>
					<div class="flex flex-col sm:flex-row justify-center gap-4">
						<a href="https://wa.me/share?text=Baca artikel menarik ini: " target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 rounded-xl bg-green-600 px-6 py-3 text-sm font-bold text-white hover:bg-green-700 transition-all hover:scale-105 shadow-lg active:scale-95">
							<Icon name="whatsapp" size={4} />
							Bagikan via WhatsApp
						</a>
						<a href="/blog" class="inline-flex items-center justify-center gap-2 rounded-xl bg-white/10 backdrop-blur-sm px-6 py-3 text-sm font-bold text-white border border-white/20 hover:bg-white/20 transition-all hover:scale-105 active:scale-95">
							<Icon name="arrow-left" size={4} />
							Kembali ke Blog
						</a>
					</div>
				</div>

				<!-- Related Posts -->
				{relatedPosts.length > 0 && (
					<div class="pt-12 border-t border-warm-200">
						<h3 class="mb-8 text-2xl font-bold text-warm-900 flex items-center gap-3">
							<span class="h-8 w-1 bg-primary-600 rounded-full"></span>
							Artikel Terkait
						</h3>
						<!-- Mobile: horizontal snap carousel dengan negatif margin agar full-bleed / Desktop: grid -->
						<div class="-mx-4 px-4 flex gap-6 overflow-x-auto snap-x snap-mandatory scroll-pl-4 pb-4 sm:mx-0 sm:px-0 sm:grid sm:grid-cols-2 sm:overflow-visible sm:snap-none sm:pb-0 lg:grid-cols-3">
							{relatedPosts.map(post => (
								<a href={`/blog/${post.id}`} class="group block overflow-hidden rounded-2xl border border-warm-100 bg-white hover:border-primary-200 hover:shadow-md transition-all w-[75vw] min-w-[260px] sm:w-auto sm:min-w-0 snap-start shrink-0 sm:shrink">
									<div class="aspect-video overflow-hidden">
										<img src={post.data.image || '/logo-yayasan.webp'} alt={post.data.title} class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-500" />
									</div>
									<div class="p-4">
										<h4 class="font-bold text-warm-900 group-hover:text-primary-700 transition-colors line-clamp-2 mb-2">
											{post.data.title}
										</h4>
										<p class="text-xs text-warm-500 line-clamp-2 leading-relaxed">
											{post.data.description}
										</p>
									</div>
								</a>
							))}
						</div>
					</div>
				)}
			</div>
		</div>
	</Container>
</BaseLayout>
