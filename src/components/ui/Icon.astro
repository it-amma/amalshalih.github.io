---

{
	fillIcons.includes(name) ? (
		<svg class:list={[`h-${size} w-${size}`, className]} width={pixelSize} height={pixelSize} fill="currentColor" viewBox="0 0 24 24">
			{paths[name].map((p) => <path d={p.d} />)}
		</svg>
	) : (
		<svg class:list={[`h-${size} w-${size}`, className]} width={pixelSize} height={pixelSize} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
			{paths[name].map((p) => <path stroke-linecap="round" stroke-linejoin="round" d={p.d} />)}
		</svg>
	)
}
