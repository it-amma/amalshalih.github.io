---
interface Props {
	class?: string;
	as?: 'section' | 'div' | 'article' | 'header' | 'footer' | 'nav';
	id?: string;
}

const { class: className, as: Tag = 'section', id } = Astro.props;
---

<Tag class:list={['mx-auto max-w-6xl px-4 sm:px-6 lg:px-8', className]} {...(id && { id })}>
	<slot />
</Tag>
