# Sentry — Error Tracking
# https://docs.sentry.io/platforms/javascript/guides/astro/
# Generate token: https://sentry.io/settings/account/api/auth-tokens/
# Required scopes: org:read, project:releases, project:write
SENTRY_AUTH_TOKEN=

# Sanity CMS — Read Token (untuk fetch konten dari Sanity)
# Dapatkan dari: https://sanity.io/manage → Project → API → Add API Token
# Role: Viewer
SANITY_API_READ_TOKEN="sk-xxxxxxxxxxxx"

# Google Drive API — Service Account (untuk galeri foto)
# 1. Buat Service Account di Google Cloud Console → IAM & Admin → Service Accounts
# 2. Buat JSON key, copy seluruh isi JSON ke variable ini
# 3. Share folder Google Drive ke email Service Account (ada di JSON key: client_email)
GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}'

# Resend — Email API (untuk form kontak)
# Dapatkan API key dari: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxx"
