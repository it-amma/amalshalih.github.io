# Environment Variables Template — Yayasan Amal Shalih Website
# 
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env file to git! It's already in .gitignore.

# =============================================================================
# SENTRY — Error Tracking
# =============================================================================
# Docs: https://docs.sentry.io/platforms/javascript/guides/astro/
# Generate token: https://sentry.io/settings/account/api/auth-tokens/
# Required scopes: org:read, project:releases, project:write
SENTRY_AUTH_TOKEN=

# =============================================================================
# SANITY CMS — API Tokens
# =============================================================================
# Manage tokens: https://sanity.io/manage → Project → API

# Read Token (untuk fetch konten dari Sanity ke website)
# Role: Viewer
# Used in: src/lib/sanity/client.ts
SANITY_API_READ_TOKEN="sk-xxxxxxxxxxxx"

# Write Token (untuk seeding data/scripts)
# Role: Editor atau Administrator
# Only needed for content management scripts
SANITY_API_WRITE_TOKEN=

# =============================================================================
# GOOGLE DRIVE API — Service Account
# =============================================================================
# Used for: Galeri foto feature
# 
# Setup instructions:
# 1. Buat Service Account di Google Cloud Console → IAM & Admin → Service Accounts
# 2. Buat JSON key, download file JSON
# 3. Copy seluruh isi JSON ke variable ini (paste sebagai string)
# 4. Share folder Google Drive ke email Service Account (ada di JSON key: client_email)
#
# Example format:
# GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'
GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY=

# =============================================================================
# FIREBASE — Realtime Database & Admin SDK
# =============================================================================
# Used for: Fitur Like Gallery, Firebase Admin operations
# 
# Setup instructions:
# 1. Download service account key dari Firebase Console:
#    https://console.firebase.google.com → Project Settings → Service Accounts
# 2. Generate new private key, download JSON file
# 3. Store JSON file di .firebase/ directory (already gitignored)
# 4. Paste entire JSON content here as string
#
# Firebase Realtime Database URL
# Example: https://amalshalih-fd1bd-default-rtdb.firebaseio.com
FIREBASE_RTDB_URL=

# Firebase Admin SDK Service Account Key
# Paste entire JSON content from downloaded key file
FIREBASE_SERVICE_ACCOUNT_KEY=

# =============================================================================
# RESEND — Email API (OPTIONAL)
# =============================================================================
# Used for: Form kontak, transactional emails
# Get API key: https://resend.com/api-keys
#
# Note: Currently using Formspree for contact form.
# Uncomment if switching to Resend.
# RESEND_API_KEY="re_xxxxxxxxxxxx"

# =============================================================================
# OTHER SERVICES (OPTIONAL)
# =============================================================================

# Formspree (alternative to Resend for contact form)
# FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id

# Cloudflare (for Workers deployment)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# =============================================================================
# NOTES
# =============================================================================
# - Keep this file updated when new environment variables are added
# - Document each variable with:
#   * What it's used for
#   * How to obtain/generate the value
#   * Links to relevant documentation
# - Use clear section headers for organization
# - Mark optional variables clearly