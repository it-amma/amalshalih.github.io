# Sentry — Error Tracking
# https://docs.sentry.io/platforms/javascript/guides/astro/
# Generate token: https://sentry.io/settings/account/api/auth-tokens/
# Required scopes: org:read, project:releases, project:write
SENTRY_AUTH_TOKEN=

# Sanity CMS — Read Token (untuk fetch konten dari Sanity)
# Dapatkan dari: https://sanity.io/manage → Project → API → Add API Token
# Role: Viewer
SANITY_API_READ_TOKEN="sk-xxxxxxxxxxxx"
